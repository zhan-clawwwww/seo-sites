---
/**
 * 频道线性图标（非 emoji），与首页 channel 卡片 --card-color 搭配 currentColor
 */
interface Props {
  slug: string;
  class?: string;
  size?: number;
}

const { slug, class: className = "", size = 24 } = Astro.props as Props;

const common = {
  width: size,
  height: size,
  viewBox: "0 0 24 24",
  fill: "none",
  "stroke-width": size <= 16 ? 2 : 1.75,
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
} as const;
---

<svg
  class={`channel-glyph ${className}`}
  {...common}
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  stroke="currentColor"
>
  {
    slug === "vpn-usa" && (
      <>
        <path d="M12 2.5 4.5 6.2v5.8c0 4.2 2.8 8.2 7.5 9.8 4.7-1.6 7.5-5.6 7.5-9.8V6.2L12 2.5z" />
        <path d="M9.2 12.2 11 14l3.8-4.6" />
      </>
    )
  }
  {
    slug === "ai" && (
      <>
        <rect x="5" y="5" width="14" height="14" rx="2.5" />
        <path d="M9 9h6v6H9z" />
        <path d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2" />
      </>
    )
  }
  {
    slug === "apple" && (
      <>
        <rect x="6" y="3" width="12" height="18" rx="2.5" />
        <path d="M10 19.5h4" />
      </>
    )
  }
  {
    slug === "streaming" && (
      <>
        <rect x="2.5" y="4.5" width="19" height="13" rx="2" />
        <path d="M8 22h8" />
        <path d="M10.2 9.8v4.4l3.8-2.2-3.8-2.2z" fill="currentColor" stroke="none" />
      </>
    )
  }
  {
    slug === "web3" && (
      <>
        <rect x="3" y="10" width="5.5" height="8" rx="1" />
        <rect x="9.25" y="6" width="5.5" height="12" rx="1" />
        <rect x="15.5" y="8.5" width="5.5" height="9.5" rx="1" />
        <path d="M8.5 13.5h.75M14.75 11.5h.75M14.75 15.5h.75" />
      </>
    )
  }
  {
    slug === "site-a" && (
      <>
        <path d="M8.5 8.5 5.5 12l3 3.5M15.5 8.5l3 3.5-3 3.5" />
        <path d="M13.5 7l-3 10" />
      </>
    )
  }
  {
    slug === "tesla" && (
      <path
        d="M13.2 3.2 7.8 14.2h4.1L9.4 20.8 18.2 9.8h-4.2l3.2-6.6z"
        fill="currentColor"
        stroke="none"
      />
    )
  }
  {
    slug === "openclaw" && (
      <>
        <circle cx="12" cy="6" r="2" />
        <circle cx="6" cy="16" r="2" />
        <circle cx="18" cy="16" r="2" />
        <path d="M10.8 7.5 7.2 14.2M13.2 7.5 16.8 14.2M7.8 16h8.4" />
      </>
    )
  }
  {
    ![
      "vpn-usa",
      "ai",
      "apple",
      "streaming",
      "web3",
      "site-a",
      "tesla",
      "openclaw",
    ].includes(slug) && (
      <>
        <rect x="3" y="3" width="7.5" height="7.5" rx="1.5" />
        <rect x="13.5" y="3" width="7.5" height="7.5" rx="1.5" />
        <rect x="3" y="13.5" width="7.5" height="7.5" rx="1.5" />
        <rect x="13.5" y="13.5" width="7.5" height="7.5" rx="1.5" />
      </>
    )
  }
</svg>
