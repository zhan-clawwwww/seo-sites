---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SBTI 人格测试 - wordok.top</title>
  <meta name="description" content="SBTI 人格测试，31 题趣味人格画像，仅供娱乐。" />
  <meta name="robots" content="index,follow" />
  <link rel="canonical" href="https://wordok.top/sbti/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    :root {
      --bg: #f8f8fa;
      --surface: #ffffff;
      --surface-hover: #f4f4f5;
      --text: #18181b;
      --text-secondary: #3f3f46;
      --muted: #52525b;
      --line: #e4e4e7;
      --soft: #f3f0ff;
      --accent: #6d28d9;
      --accent-hover: #5b21b6;
      --accent-border: rgba(109, 40, 217, 0.35);
      --gradient: linear-gradient(120deg, #5b21b6 0%, #0891b2 100%);
      --shadow: 0 4px 20px rgba(15, 23, 42, 0.06);
      --radius: 14px;
      --font: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #09090b;
        --surface: #18181b;
        --surface-hover: #27272a;
        --text: #fafafa;
        --text-secondary: #e4e4e7;
        --muted: #d4d4d8;
        --line: #3f3f46;
        --soft: #27272a;
        --accent: #a78bfa;
        --accent-hover: #c4b5fd;
        --accent-border: rgba(167, 139, 250, 0.45);
        --gradient: linear-gradient(120deg, #a78bfa 0%, #22d3ee 100%);
        --shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
      }
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; scroll-padding-top: 72px; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.6; min-height: 100vh; -webkit-font-smoothing: antialiased; }
    .shell { max-width: 720px; margin: 0 auto; padding: 20px 16px 32px; }
    .page-header { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid var(--line); }
    .brand-link { display: inline-flex; align-items: center; gap: 6px; color: var(--accent); text-decoration: none; font-weight: 700; font-size: 14px; padding: 8px 14px; border-radius: 999px; border: 1px solid var(--line); background: var(--surface); transition: background 0.2s, border-color 0.2s; }
    .brand-link:hover { background: var(--surface-hover); border-color: var(--accent); text-decoration: none; }
    .page-title { font-size: clamp(20px, 4vw, 26px); font-weight: 800; color: var(--text); letter-spacing: -0.02em; }
    .intro-banner { background: var(--surface); border: 1px solid var(--line); border-left: 4px solid var(--accent); border-radius: var(--radius); padding: 18px 20px; margin-bottom: 22px; box-shadow: 0 1px 0 rgba(0,0,0,0.04); }
    .intro-banner p { color: var(--text-secondary); font-size: 14px; margin: 0; line-height: 1.75; }
    .intro-banner strong { color: var(--text); font-weight: 700; }
    .progress-wrap { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; position: sticky; top: 0; z-index: 10; background: color-mix(in srgb, var(--bg) 92%, transparent); backdrop-filter: blur(8px); padding: 10px 0 12px; border-bottom: 1px solid color-mix(in srgb, var(--line) 70%, transparent); margin-left: -4px; margin-right: -4px; padding-left: 4px; padding-right: 4px; }
    .progress { flex: 1; height: 6px; background: var(--line); border-radius: 999px; overflow: hidden; }
    .progress span { display: block; height: 100%; width: 0; background: var(--gradient); border-radius: inherit; transition: width 0.28s ease; }
    .progress-text { color: var(--muted); font-size: 13px; font-weight: 600; white-space: nowrap; font-variant-numeric: tabular-nums; }
    .question-list { display: grid; gap: 14px; min-height: 80px; }
    .question-list .quiz-loading { margin: 0; padding: 32px 12px; text-align: center; color: var(--muted); font-size: 14px; letter-spacing: 0.02em; }
    .question { background: var(--surface); border: 1px solid var(--line); border-left: 3px solid var(--accent-border); border-radius: 14px; padding: 18px 18px 16px; box-shadow: var(--shadow); }
    .question-meta { display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 12px; font-size: 12px; color: var(--muted); }
    .badge { display: inline-flex; align-items: center; padding: 4px 10px; background: var(--soft); border: 1px solid var(--line); border-radius: 999px; font-weight: 600; font-size: 11px; color: var(--text-secondary); }
    .question-title { font-size: 15px; line-height: 1.72; white-space: pre-wrap; margin-bottom: 14px; color: var(--text); }
    .options { display: grid; gap: 10px; }
    /* 三列网格：单选 · 选项字母 · 文案，避免 flex + scale 导致错位、换行乱版 */
    .option {
      display: grid;
      grid-template-columns: 20px 1.75rem 1fr;
      align-items: start;
      column-gap: 12px;
      row-gap: 4px;
      padding: 14px 16px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: var(--bg);
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .option:hover { border-color: var(--accent-border); background: var(--soft); }
    .option:focus-within { outline: 2px solid color-mix(in srgb, var(--accent) 35%, transparent); outline-offset: 2px; }
    .option:has(input:checked) { border-color: var(--accent); background: var(--soft); box-shadow: inset 0 0 0 1px var(--accent-border); }
    .option input {
      margin: 4px 0 0;
      width: 18px;
      height: 18px;
      accent-color: var(--accent);
      flex-shrink: 0;
      transform: none;
    }
    .option-code {
      font-weight: 800;
      color: var(--accent);
      line-height: 1.5;
      padding-top: 2px;
    }
    .option-text {
      color: var(--text-secondary);
      font-size: 14px;
      line-height: 1.65;
      min-width: 0;
    }
    .actions-bar { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--line); }
    .hint { color: var(--muted); font-size: 13px; line-height: 1.6; flex: 1; min-width: 200px; }
    .btn-group { display: flex; gap: 10px; flex-wrap: wrap; }
    button { border: none; cursor: pointer; font: inherit; font-weight: 700; padding: 12px 20px; border-radius: 12px; transition: transform 0.15s, opacity 0.15s, background 0.15s; }
    button:hover:not(:disabled) { transform: translateY(-1px); }
    button:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover:not(:disabled) { background: var(--accent-hover); }
    .btn-secondary { background: var(--surface); color: var(--accent); border: 1px solid var(--line); }
    .btn-secondary:hover:not(:disabled) { background: var(--surface-hover); border-color: var(--accent); }
    .screen { display: none; }
    .screen.active { display: block; }
    .result-wrap { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow); }
    .result-layout { display: grid; gap: 20px; }
    .result-top { display: grid; grid-template-columns: 1fr 1.2fr; gap: 20px; align-items: stretch; }
    @media (max-width: 640px) { .result-top { grid-template-columns: 1fr; } }
    .poster-box, .type-box, .analysis-box, .dim-box, .note-box { background: var(--bg); border: 1px solid var(--line); border-radius: 14px; padding: 18px; }
    .poster-box { display: flex; flex-direction: column; min-height: 200px; }
    .poster-box.no-image .poster-image { display: none; }
    .poster-image { width: 100%; max-height: 300px; object-fit: contain; border-radius: 12px; margin-bottom: 12px; }
    .poster-caption { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: auto; }
    .type-kicker { font-size: 12px; color: var(--accent); font-weight: 600; letter-spacing: 0.05em; margin-bottom: 8px; }
    .type-name { font-size: clamp(24px, 5vw, 36px); font-weight: 800; line-height: 1.1; background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .type-subname { color: var(--text-secondary); font-size: 14px; margin-top: 10px; line-height: 1.6; }
    .match { display: inline-flex; align-items: center; gap: 6px; margin-top: 14px; padding: 8px 14px; background: var(--soft); border: 1px solid var(--line); border-radius: 999px; color: var(--accent); font-weight: 700; font-size: 13px; }
    .analysis-box h3, .dim-box h3, .note-box h3 { font-size: 15px; margin-bottom: 12px; color: var(--text); }
    .analysis-box p, .note-box p { color: var(--text-secondary); font-size: 14px; line-height: 1.8; white-space: pre-wrap; margin: 0; }
    .dim-list { display: grid; gap: 10px; }
    .dim-item { background: var(--surface); border: 1px solid var(--line); border-radius: 12px; padding: 14px; }
    .dim-item-top { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; margin-bottom: 6px; }
    .dim-item-name { font-size: 13px; font-weight: 700; color: var(--text); }
    .dim-item-score { color: var(--accent); font-weight: 800; font-size: 13px; }
    .dim-item p { color: var(--text-secondary); font-size: 12px; line-height: 1.6; margin: 0; }
    .author-box { background: var(--bg); border: 1px solid var(--line); border-radius: 14px; overflow: hidden; }
    .author-box summary { list-style: none; cursor: pointer; padding: 16px 18px; font-size: 15px; font-weight: 700; display: flex; justify-content: space-between; align-items: center; color: var(--text); }
    .author-box summary::-webkit-details-marker { display: none; }
    .author-box summary::after { content: '展开'; font-size: 12px; font-weight: 600; color: var(--accent); background: var(--soft); border: 1px solid var(--line); padding: 5px 10px; border-radius: 999px; }
    .author-box[open] summary::after { content: '收起'; }
    .author-content { border-top: 1px solid var(--line); padding: 16px 18px; }
    .author-content p { color: var(--text-secondary); font-size: 13px; line-height: 1.8; margin: 10px 0 0; }
    .author-content p:first-child { margin-top: 0; }
    .result-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--line); flex-wrap: wrap; }
    .btn-link { display: inline-block; text-decoration: none; background: var(--accent); color: #fff; font-weight: 700; padding: 12px 20px; border-radius: 12px; transition: background 0.15s; }
    .btn-link:hover { background: var(--accent-hover); text-decoration: none; }
  </style>
</head>
<body>
  <div class="shell">
    <header class="page-header">
      <a class="brand-link" href="/">← wordok.top</a>
      <h1 class="page-title">SBTI 人格测试</h1>
    </header>
    <section id="test" class="screen active">
      <div class="intro-banner">
        <p><strong>MBTI 已经过时，SBTI 来了。</strong> 共 31 道题，全部选完后即可查看你的人格画像。本测试仅供娱乐，别太当真。</p>
      </div>
      <div class="progress-wrap">
        <div class="progress"><span id="progressBar"></span></div>
        <div class="progress-text" id="progressText">0 / 31</div>
      </div>
      <div id="questionList" class="question-list">
        <p class="quiz-loading">题目加载中…</p>
      </div>
      <div class="actions-bar">
        <div class="hint" id="testHint">全选完才会放行。</div>
        <div class="btn-group">
          <button id="submitBtn" class="btn-primary" disabled>提交并查看结果</button>
        </div>
      </div>
    </section>
    <section id="result" class="screen">
      <div class="result-wrap">
        <div class="result-layout">
          <div class="result-top">
            <div class="poster-box" id="posterBox">
              <img id="posterImage" class="poster-image" alt="人格结果图" />
              <div id="posterCaption" class="poster-caption"></div>
            </div>
            <div class="type-box">
              <div class="type-kicker" id="resultModeKicker">你的主类型</div>
              <div class="type-name" id="resultTypeName"></div>
              <div class="match" id="matchBadge"></div>
              <div class="type-subname" id="resultTypeSub"></div>
            </div>
          </div>
          <div class="analysis-box">
            <h3>人格解读</h3>
            <p id="resultDesc"></p>
          </div>
          <div class="dim-box">
            <h3>十五维度评分</h3>
            <div id="dimList" class="dim-list"></div>
          </div>
          <div class="note-box">
            <h3>友情提示</h3>
            <p id="funNote"></p>
          </div>
          <details class="author-box">
            <summary>作者的话</summary>
            <div class="author-content">
              <p>本测试首发于 B 站 up 主蛆肉儿串儿（UID417038183），初衷是劝诫一位爱喝酒的朋友戒酒。</p>
              <p>由于作者的人格是 SHIT 愤世者，所以平等地攻击了各位，在此抱歉！不过我是一个绝世大美女，你们一定会原谅我。</p>
              <p>关于这个测试，我没法很好地平衡娱乐和专业性，因此对于一些人格的阐释较为模糊或完全不准，如有冒犯非常抱歉！</p>
              <p>总之好玩为主，还请不要用于盈利。</p>
            </div>
          </details>
        </div>
        <div class="result-actions">
          <button id="restartBtn" class="btn-secondary">重新测试</button>
          <a href="/" class="btn-link">返回 wordok 首页</a>
        </div>
      </div>
    </section>
  </div>
  <script is:inline src="/sbti/main.js"></script>
  <script is:inline>
    (function(){ if(typeof startTest==='function') startTest(false); })();
  </script>
</body>
</html>
