---
export const prerender = true;

import { resolveRootSiteAnalytics } from "../lib/root-analytics";
import { getAllSites, getSiteConfig } from "../lib/site-data";

const sites = getAllSites();
const firstSite = sites[0];
const analytics = resolveRootSiteAnalytics(
  firstSite ? getSiteConfig(firstSite.slug)?.analytics : undefined,
);
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SBTI 人格测试 - wordok.top</title>
  <meta name="description" content="SBTI 人格测试，31 题趣味人格画像，仅供娱乐。" />
  <meta name="robots" content="index,follow" />
  <link rel="canonical" href="https://wordok.top/sbti/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {analytics.ga4Id ? (
    <link rel="preconnect" href="https://www.googletagmanager.com" />
  ) : null}
  {analytics.ga4Id ? (
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${analytics.ga4Id}`}></script>
  ) : null}
  {analytics.ga4Id ? (
    <script define:vars={{ gaId: analytics.ga4Id }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args) {
        window.dataLayer.push(args);
      }
      gtag("js", new Date());
      gtag("config", gaId);
    </script>
  ) : null}
  <style is:global>
    :root {
      --bg: #fafafa;
      --panel: #ffffff;
      --text: #18181b;
      --muted: #52525b;
      --line: #e4e4e7;
      --soft: #f3f0ff;
      --accent: #7c3aed;
      --accent-strong: #6d28d9;
      --accent-cyan: #06b6d4;
      --accent-border: rgba(109, 40, 217, 0.28);
      --shadow: 0 16px 40px rgba(109, 40, 217, 0.09);
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06);
      --radius: 22px;
      --gradient: linear-gradient(120deg, #7c3aed 0%, #8b5cf6 45%, #06b6d4 100%);
      --font: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0c0a12;
        --panel: #16121f;
        --text: #f4f4f5;
        --muted: #a1a1aa;
        --line: #2e2654;
        --soft: rgba(167, 139, 250, 0.14);
        --accent: #a78bfa;
        --accent-strong: #c4b5fd;
        --accent-cyan: #22d3ee;
        --accent-border: rgba(167, 139, 250, 0.35);
        --shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        --shadow-sm: 0 4px 16px rgba(0, 0, 0, 0.35);
        --gradient: linear-gradient(120deg, #a78bfa 0%, #c4b5fd 45%, #22d3ee 100%);
      }
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font);
      background-color: var(--bg);
      background-image:
        radial-gradient(circle at top left, rgba(124, 58, 237, 0.07) 0%, transparent 40%),
        radial-gradient(circle at bottom right, rgba(6, 182, 212, 0.06) 0%, transparent 40%);
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    @media (prefers-color-scheme: dark) {
      body {
        background-image:
          radial-gradient(circle at top left, rgba(167, 139, 250, 0.10) 0%, transparent 40%),
          radial-gradient(circle at bottom right, rgba(34, 211, 238, 0.07) 0%, transparent 40%);
      }
    }
    .site-nav {
      width: 100%;
      background: var(--panel);
      border-bottom: 1px solid var(--line);
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: var(--shadow-sm);
    }
    .site-nav.bottom-nav {
      position: static;
      border-bottom: none;
      border-top: 1px solid var(--line);
    }
    .nav-inner {
      max-width: 980px;
      margin: 0 auto;
      padding: 0 16px;
      height: 52px;
      display: flex;
      align-items: center;
      gap: 16px;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    .nav-brand {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-weight: 800;
      font-size: 15px;
      color: var(--accent);
      text-decoration: none;
      transition: opacity 0.15s;
      white-space: nowrap;
    }
    .nav-brand:hover { opacity: 0.8; }
    .nav-tip {
      font-size: 13px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
    }
    .nav-tip .dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--gradient);
      flex-shrink: 0;
      display: inline-block;
    }
    .nav-tip a { color: var(--accent); text-decoration: none; font-weight: 600; }
    .nav-tip a:hover { text-decoration: underline; }
    .shell { max-width: 980px; margin: 0 auto; padding: 24px 16px 56px; }
    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }
    .card::after {
      content: "";
      position: absolute;
      right: -60px; top: -60px;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(124, 58, 237, 0.12), transparent 65%);
      pointer-events: none;
    }
    @media (prefers-color-scheme: dark) {
      .card::after { background: radial-gradient(circle, rgba(167, 139, 250, 0.10), transparent 65%); }
    }
    .card > * { position: relative; z-index: 1; }
    .screen { display: none; }
    .screen.active { display: block; }
    .quiz-hero {
      padding: 28px 24px 20px;
      border-bottom: 1px solid var(--line);
      text-align: center;
    }
    .quiz-credit {
      margin: 0 0 14px;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
    }
    .quiz-credit a {
      color: var(--accent);
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1px solid rgba(124, 58, 237, 0.35);
    }
    .quiz-credit a:hover { opacity: 0.85; border-bottom-color: var(--accent); }
    @media (prefers-color-scheme: dark) {
      .quiz-credit a { border-bottom-color: rgba(167, 139, 250, 0.4); }
    }
    .quiz-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 12px; font-weight: 600;
      color: var(--accent);
      border: 1px solid var(--line);
      background: var(--soft);
      border-radius: 999px;
      padding: 7px 14px;
      margin-bottom: 16px;
      letter-spacing: 0.04em;
    }
    .quiz-hero h1 {
      font-size: clamp(26px, 4.5vw, 44px);
      line-height: 1.12; letter-spacing: -0.03em; font-weight: 800;
      background: var(--gradient);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      margin: 0;
    }
    .quiz-hero .sub {
      margin-top: 12px; color: var(--muted); font-size: 14px; line-height: 1.75;
    }
    .test-wrap, .result-wrap { margin-top: 22px; }
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      padding: 16px 24px 14px;
      border-bottom: 1px solid var(--line);
      flex-wrap: wrap;
      position: sticky;
      top: 52px; z-index: 10;
      background: color-mix(in srgb, var(--panel) 96%, transparent);
      backdrop-filter: blur(10px);
    }
    .progress {
      flex: 1; min-width: 200px;
      height: 10px;
      background: color-mix(in srgb, var(--line) 80%, var(--soft));
      border-radius: 999px; overflow: hidden;
    }
    .progress > span {
      display: block; width: 0; height: 100%;
      background: var(--gradient);
      border-radius: inherit;
      transition: width 0.25s ease;
      box-shadow: 0 0 10px rgba(124, 58, 237, 0.3);
    }
    @media (prefers-color-scheme: dark) {
      .progress > span { box-shadow: 0 0 10px rgba(167, 139, 250, 0.4); }
    }
    .progress-text { color: var(--muted); font-size: 13px; font-weight: 600; white-space: nowrap; font-variant-numeric: tabular-nums; }
    .question-list { display: grid; gap: 16px; padding: 20px 24px; }
    .quiz-loading { text-align: center; color: var(--muted); font-size: 14px; padding: 32px 0; }
    .question {
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 0;
      background: linear-gradient(180deg, var(--panel), color-mix(in srgb, var(--bg) 35%, var(--panel)));
      position: relative; overflow: hidden;
    }
    .question::before {
      content: "";
      position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
      background: var(--gradient);
      border-radius: 18px 0 0 18px;
      opacity: 0.7;
    }
    .question-meta {
      display: flex; justify-content: space-between; align-items: center;
      gap: 12px; padding: 12px 16px 10px 18px;
      border-bottom: 1px solid color-mix(in srgb, var(--line) 80%, transparent);
      color: var(--muted); font-size: 12px;
    }
    .badge {
      display: inline-flex; align-items: center; gap: 6px;
      border-radius: 999px; padding: 5px 10px;
      background: var(--soft); border: 1px solid var(--line);
      font-weight: 700; font-size: 11px; color: var(--accent);
    }
    .question-dim {
      font-size: 11px; font-weight: 600; color: var(--muted);
      padding: 4px 10px; border-radius: 999px;
      background: color-mix(in srgb, var(--bg) 70%, var(--panel));
      border: 1px solid var(--line);
    }
    /* question-stem: big number + title */
    .question-stem {
      display: grid;
      grid-template-columns: 3rem 1fr;
      gap: 10px 14px;
      align-items: start;
      padding: 14px 16px 16px 18px;
    }
    @media (max-width: 480px) {
      .question-stem { grid-template-columns: 2.5rem 1fr; padding-left: 14px; }
    }
    .question-index {
      font-size: clamp(24px, 5vw, 30px);
      font-weight: 800; line-height: 1;
      letter-spacing: -0.04em; font-variant-numeric: tabular-nums;
      background: var(--gradient);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      user-select: none; padding-top: 3px;
    }
    .question-title-wrap { min-width: 0; }
    .question-title {
      font-size: 15px; line-height: 1.75; white-space: pre-wrap;
      font-weight: 600; color: var(--text); margin: 0;
    }
    /* options head */
    .options-head {
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 10px; padding-top: 2px;
    }
    .options-head-icon {
      display: inline-block; width: 6px; height: 6px;
      border-radius: 50%; background: var(--gradient); flex-shrink: 0;
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent);
    }
    .options-head-text {
      font-size: 11px; font-weight: 700;
      color: var(--muted); letter-spacing: 0.06em;
    }
    /* ===== Options ===== */
    .options {
      display: flex; flex-direction: column; gap: 0;
      padding: 0 14px 16px 18px; margin-top: 0;
    }
    .option {
      display: grid;
      grid-template-columns: 18px auto 1fr;
      align-items: start;
      column-gap: 12px;
      padding: 12px 14px;
      margin-bottom: 8px;
      border-radius: 14px;
      border: 1px solid var(--line); background: var(--panel);
      cursor: pointer;
      transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    }
    @media (prefers-color-scheme: dark) {
      .option { background: color-mix(in srgb, var(--panel) 85%, var(--bg)); }
    }
    .option:hover {
      border-color: var(--accent-border);
      background: color-mix(in srgb, var(--soft) 50%, var(--panel));
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(124, 58, 237, 0.08);
    }
    @media (prefers-color-scheme: dark) {
      .option:hover { box-shadow: 0 4px 12px rgba(167, 139, 250, 0.15); }
    }
    .option:has(input:checked) {
      border-color: var(--accent);
      background: color-mix(in srgb, var(--soft) 70%, var(--panel));
      box-shadow: inset 0 0 0 1px var(--accent-border), 0 4px 16px rgba(124, 58, 237, 0.12);
      transform: translateY(0);
    }
    .option:last-child { margin-bottom: 0; }
    .option input {
      margin-top: 10px; accent-color: var(--accent);
      width: 16px; height: 16px; flex-shrink: 0; cursor: pointer;
    }
    .option-key {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 2.1rem; height: 2.1rem;
      margin-top: 4px; padding: 0 6px;
      border-radius: 9px;
      border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent) 15%);
      background: linear-gradient(180deg, color-mix(in srgb, var(--soft) 80%, var(--panel)), var(--panel));
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }
    @media (prefers-color-scheme: dark) {
      .option-key { background: linear-gradient(180deg, var(--soft), var(--panel)); }
    }
    .option-code {
      font-weight: 800; font-size: 13px; color: var(--accent); line-height: 1;
    }
    .option:has(input:checked) .option-key {
      background: var(--gradient); border-color: transparent;
      box-shadow: 0 3px 10px rgba(109, 40, 217, 0.25);
    }
    .option:has(input:checked) .option-code { color: #fff; }
    .option-text {
      color: var(--muted); font-size: 14px; line-height: 1.65;
      padding-top: 6px;
    }
    @media (prefers-color-scheme: dark) {
      .option-text { color: color-mix(in srgb, var(--text) 75%, var(--muted)); }
    }
    .option:has(input:checked) .option-text { color: var(--text); }
    .actions-bottom {
      display: flex; justify-content: space-between; align-items: center;
      gap: 12px; flex-wrap: wrap;
      padding: 16px 24px 20px;
      border-top: 1px solid var(--line);
    }
    .hint { color: var(--muted); font-size: 13px; line-height: 1.7; flex: 1; min-width: 160px; }
    button {
      border: 0; cursor: pointer; font: inherit; font-weight: 700;
      padding: 13px 20px; border-radius: 14px;
      transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s, background 0.15s;
    }
    button:hover:not(:disabled) { transform: translateY(-1px); }
    button:disabled { cursor: not-allowed; opacity: 0.5; transform: none; }
    .btn-primary {
      background: var(--gradient); color: #fff;
      box-shadow: 0 10px 28px rgba(109, 40, 217, 0.28);
    }
    .btn-primary:hover:not(:disabled) { box-shadow: 0 12px 32px rgba(109, 40, 217, 0.38); }
    @media (prefers-color-scheme: dark) {
      .btn-primary { box-shadow: 0 8px 24px rgba(167, 139, 250, 0.3); }
    }
    .btn-secondary {
      background: var(--panel); color: var(--accent);
      border: 1px solid var(--line); box-shadow: var(--shadow-sm);
    }
    .btn-secondary:hover:not(:disabled) { background: var(--soft); border-color: var(--accent-border); }
    .result-wrap { padding: 28px 24px 30px; }
    .result-layout { display: grid; gap: 20px; }
    .result-top { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 18px; align-items: stretch; }
    @media (max-width: 640px) { .result-top { grid-template-columns: 1fr; } }
    .poster-box, .type-box, .analysis-box, .dim-box, .note-box {
      border: 1px solid var(--line); border-radius: 18px; padding: 18px;
      background: linear-gradient(180deg, var(--panel), color-mix(in srgb, var(--bg) 35%, var(--panel)));
    }
    .poster-box {
      display: grid; grid-template-rows: 1fr auto;
      min-height: 260px; overflow: hidden; position: relative;
      background:
        radial-gradient(circle at top right, rgba(124, 58, 237, 0.10), transparent 40%),
        linear-gradient(180deg, var(--panel), color-mix(in srgb, var(--bg) 30%, var(--panel)));
    }
    @media (prefers-color-scheme: dark) {
      .poster-box {
        background:
          radial-gradient(circle at top right, rgba(167, 139, 250, 0.08), transparent 40%),
          linear-gradient(180deg, var(--panel), var(--bg));
      }
    }
    .poster-image {
      width: 100%; min-height: 200px; max-height: 420px;
      object-fit: contain; border-radius: 14px;
      background: color-mix(in srgb, var(--bg) 50%, transparent);
    }
    .poster-box.no-image .poster-image { display: none; }
    .poster-caption { margin-top: 14px; color: var(--muted); font-size: 14px; line-height: 1.8; }
    .type-kicker { font-size: 12px; font-weight: 700; color: var(--accent); margin-bottom: 8px; letter-spacing: 0.06em; }
    .type-name {
      font-size: clamp(28px, 5vw, 44px);
      line-height: 1.08; letter-spacing: -0.03em; font-weight: 800;
      background: var(--gradient);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .type-subname { margin-top: 10px; color: var(--muted); font-size: 14px; line-height: 1.8; }
    .match {
      margin-top: 16px;
      display: inline-flex; align-items: center; gap: 8px;
      border-radius: 999px; padding: 9px 14px;
      background: var(--soft); border: 1px solid var(--line);
      color: var(--accent); font-weight: 700; font-size: 14px;
    }
    @media (prefers-color-scheme: dark) { .match { color: var(--accent-strong); } }
    .analysis-box h3, .dim-box h3, .note-box h3 {
      font-size: 16px; font-weight: 700; margin-bottom: 12px;
      padding-bottom: 8px; border-bottom: 1px solid var(--line); color: var(--text);
    }
    .analysis-box p, .note-box p {
      margin: 0; color: var(--muted); font-size: 14px; line-height: 1.9; white-space: pre-wrap;
    }
    @media (prefers-color-scheme: dark) {
      .analysis-box p { color: color-mix(in srgb, var(--text) 80%, var(--muted)); }
    }
    .dim-list { display: grid; gap: 12px; }
    .dim-item { border: 1px solid var(--line); border-radius: 14px; padding: 13px 14px; background: var(--panel); }
    .dim-item-top { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; margin-bottom: 6px; flex-wrap: wrap; }
    .dim-item-name { font-size: 13px; font-weight: 700; color: var(--text); }
    .dim-item-score { color: var(--accent); font-weight: 800; font-size: 13px; white-space: nowrap; }
    .dim-item p { margin: 0; color: var(--muted); font-size: 12px; line-height: 1.75; }
    .author-box {
      border: 1px solid var(--line); border-radius: 18px;
      background: linear-gradient(180deg, var(--panel), color-mix(in srgb, var(--bg) 30%, var(--panel)));
      overflow: hidden;
    }
    .author-box summary {
      list-style: none; cursor: pointer; padding: 16px 18px;
      font-size: 15px; font-weight: 700; color: var(--text);
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
    }
    .author-box summary::-webkit-details-marker { display: none; }
    .author-box summary::after {
      content: '展开';
      font-size: 12px; font-weight: 700; color: var(--accent);
      border: 1px solid var(--line); background: var(--soft);
      padding: 6px 12px; border-radius: 999px; flex-shrink: 0;
    }
    .author-box[open] summary::after { content: '收起'; }
    .author-content { border-top: 1px solid var(--line); padding: 0 18px 18px; }
    .author-content p { margin: 14px 0 0; color: var(--muted); font-size: 14px; line-height: 1.9; }
    .result-actions {
      display: flex; justify-content: space-between; align-items: center;
      gap: 12px; flex-wrap: wrap;
      margin-top: 24px; padding-top: 20px;
      border-top: 1px solid var(--line);
    }
    .btn-link {
      display: inline-block; text-decoration: none;
      background: var(--gradient); color: #fff;
      font-weight: 700; padding: 13px 20px;
      border-radius: 14px; font-size: 14px;
      box-shadow: 0 8px 22px rgba(109, 40, 217, 0.25);
      transition: opacity 0.15s, transform 0.15s, box-shadow 0.15s;
    }
    .btn-link:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 12px 28px rgba(109, 40, 217, 0.35); text-decoration: none; }
    .bottom-nav .nav-inner { height: auto; padding-top: 14px; padding-bottom: 14px; }
    .bottom-nav-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 8px; }
    .bottom-nav-links a { font-size: 12px; color: var(--muted); text-decoration: none; transition: color 0.15s; }
    .bottom-nav-links a:hover { color: var(--accent); }
    @media (max-width: 600px) {
      .shell { padding: 14px 12px 42px; }
      .quiz-hero { padding: 22px 18px 16px; }
      .question-list { padding: 16px; }
      .topbar { padding: 12px 16px 10px; top: 48px; }
      .actions-bottom { padding: 14px 16px 18px; }
      .result-wrap { padding: 20px 16px 24px; }
      .nav-tip { display: none; }
    }
    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      .option:hover, button:hover:not(:disabled) { transform: none; }
      .progress > span { transition: none; }
    }
  </style>
</head>
<body>

  <nav class="site-nav top-nav" role="navigation" aria-label="站点导航">
    <div class="nav-inner">
      <a class="nav-brand" href="https://wordok.top">← wordok.top</a>
      <span class="nav-tip">
        <span class="dot"></span>
        在 <a href="https://wordok.top">wordok.top</a> 可以看到最新的科技新闻，AI · Web3 · Tesla · VPN
      </span>
    </div>
  </nav>

  <div class="shell">

    <section id="test" class="screen active">
      <div class="test-wrap card">

        <div class="quiz-hero">
          <p class="quiz-credit">
            原作者：
            <a href="https://space.bilibili.com/417038183" target="_blank" rel="noopener noreferrer">B站@蛆肉儿串儿</a>
          </p>
          <div class="quiz-eyebrow">wordok · 31 题 · 仅供娱乐</div>
          <h1>MBTI已经过时，SBTI来了。</h1>
