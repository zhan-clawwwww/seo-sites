---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllSites, getSiteConfig, toCanonical } from "../lib/site-data";

const sites = getAllSites();
const firstSite = sites[0];
const analytics = firstSite ? getSiteConfig(firstSite.slug)?.analytics : undefined;

if (sites.length === 1) {
  return Astro.redirect(`/${sites[0].slug}/`, 301);
}

const rootBaseUrl =
  import.meta.env.PUBLIC_ROOT_BASE_URL?.toString().trim() || "https://wordok.top";
const canonical = toCanonical(rootBaseUrl, "/");

const openGraph = {
  type: "website" as const,
  title: "wordok.top — VPN Reviews & AI News",
  description: "Expert VPN reviews for the USA and latest AI news. Choose your channel to explore.",
  url: canonical,
  siteName: "wordok.top",
};

const twitter = {
  card: "summary" as const,
  title: "wordok.top — VPN Reviews & AI News",
  description: "Expert VPN reviews and AI news. Choose your channel to explore.",
};

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "wordok.top Channels",
  "description": "wordok.top content channels",
  "numberOfItems": sites.length,
  "itemListElement": sites.map((s, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": s.config.name,
    "url": toCanonical(rootBaseUrl, `/${s.slug}/`),
  })),
};

const columnMeta: Record<string, { label: string; desc: string; icon: string }> = {
  "vpn-usa": {
    label: "VPN",
    desc: "Best USA VPN reviews and buying guides",
    icon: "🔒",
  },
  ai: {
    label: "AI News",
    desc: "Latest AI news and industry insights",
    icon: "🤖",
  },
  apple: {
    label: "Apple",
    desc: "iPhone & MacBook specs and reviews (2010–present)",
    icon: "🍎",
  },
};
---

<BaseLayout
  title="wordok.top — Choose Your Channel"
  description="Expert VPN reviews for the USA and latest AI news. Choose your channel to explore."
  canonical={canonical}
  keywords={["wordok", "VPN reviews", "AI news", "USA VPN", "AI insights"]}
  openGraph={openGraph}
  twitter={twitter}
  jsonLd={itemListJsonLd}
  analytics={analytics}
>
  <div class="portal">
    <h1 class="portal-title">wordok.top</h1>
    <p class="portal-subtitle">Choose a channel</p>

    <div class="portal-sitemap-links">
      <a href="/sitemap/">站点地图</a>
      <a href="/sitemap.xml">sitemap.xml</a>
    </div>

    <nav class="portal-cards" aria-label="Channel navigation">
      {sites.map((s) => {
        const meta = columnMeta[s.slug] ?? { label: s.config.name, desc: s.config.description, icon: "📄" };
        return (
          <a href={`/${s.slug}/`} class="portal-card">
            <span class="portal-card-icon" aria-hidden="true">{meta.icon}</span>
            <span class="portal-card-title">{meta.label}</span>
            <span class="portal-card-desc">{meta.desc}</span>
          </a>
        );
      })}
    </nav>
  </div>

  <style>
    .portal {
      max-width: 480px;
      margin: 0 auto;
      padding: 56px 20px 72px;
      min-height: 70vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .portal-title {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0 0 6px;
      color: var(--color-text);
    }
    .portal-subtitle {
      font-size: 0.95rem;
      color: var(--color-text-secondary);
      margin: 0 0 8px;
      font-weight: 400;
    }
    .portal-sitemap-links {
      display: flex;
      gap: 16px;
      margin-bottom: 32px;
    }
    .portal-sitemap-links a {
      font-size: 0.85rem;
      color: var(--color-text-secondary);
      text-decoration: none;
    }
    .portal-sitemap-links a:hover {
      color: var(--color-primary);
    }
    .portal-cards {
      display: flex;
      flex-direction: column;
      gap: 12px;
      width: 100%;
    }
    .portal-card {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 18px 20px;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      text-decoration: none !important;
      transition: border-color 0.2s, background 0.2s;
    }
    .portal-card:hover {
      border-color: var(--color-primary);
      background: var(--color-surface-hover);
    }
    .portal-card-icon {
      font-size: 1.5rem;
      flex-shrink: 0;
    }
    .portal-card-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text);
    }
    .portal-card-desc {
      font-size: 0.8rem;
      color: var(--color-text-secondary);
      margin-left: auto;
      max-width: 180px;
      text-align: right;
      line-height: 1.4;
    }
    @media (max-width: 480px) {
      .portal { padding: 40px 16px 56px; }
      .portal-title { font-size: 1.5rem; }
      .portal-card-desc { display: none; }
    }
  </style>
</BaseLayout>
