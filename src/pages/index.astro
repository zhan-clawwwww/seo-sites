---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllSites, toCanonical } from "../lib/site-data";

const sites = getAllSites();

if (sites.length === 1) {
  return Astro.redirect(`/${sites[0].slug}/`, 301);
}

const rootBaseUrl =
  import.meta.env.PUBLIC_ROOT_BASE_URL?.toString().trim() || "https://wordok.top";
const canonical = toCanonical(rootBaseUrl, "/");

const openGraph = {
  type: "website" as const,
  title: "wordok.top — VPN Reviews & AI News",
  description: "Expert VPN reviews for the USA and latest AI news. Choose your channel to explore.",
  url: canonical,
  siteName: "wordok.top",
};

const twitter = {
  card: "summary" as const,
  title: "wordok.top — VPN Reviews & AI News",
  description: "Expert VPN reviews and AI news. Choose your channel to explore.",
};

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "wordok.top Channels",
  "description": "wordok.top content channels",
  "numberOfItems": sites.length,
  "itemListElement": sites.map((s, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": s.config.name,
    "url": toCanonical(rootBaseUrl, `/${s.slug}/`),
  })),
};

const columnMeta: Record<string, { label: string; desc: string; icon: string }> = {
  "vpn-usa": {
    label: "VPN",
    desc: "Best USA VPN reviews and buying guides",
    icon: "🔒",
  },
  ai: {
    label: "AI News",
    desc: "Latest AI news and industry insights",
    icon: "🤖",
  },
};
---

<BaseLayout
  title="wordok.top — Choose Your Channel"
  description="Expert VPN reviews for the USA and latest AI news. Choose your channel to explore."
  canonical={canonical}
  keywords={["wordok", "VPN reviews", "AI news", "USA VPN", "AI insights"]}
  openGraph={openGraph}
  twitter={twitter}
  jsonLd={itemListJsonLd}
>
  <div class="portal">
    <h1 class="portal-title">wordok.top</h1>
    <p class="portal-subtitle">Choose your channel</p>

    <div class="portal-cards">
      {sites.map((s) => {
        const meta = columnMeta[s.slug] ?? { label: s.config.name, desc: s.config.description, icon: "📄" };
        return (
          <a href={`/${s.slug}/`} class="portal-card">
            <span class="portal-card-icon">{meta.icon}</span>
            <h2 class="portal-card-title">{meta.label}</h2>
            <p class="portal-card-desc">{meta.desc}</p>
            <span class="portal-card-cta">Enter channel →</span>
          </a>
        );
      })}
    </div>
  </div>

  <style>
    .portal {
      text-align: center;
      padding: 48px 24px 64px;
      min-height: 60vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .portal-title {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin: 0 0 8px;
      color: var(--color-text);
    }
    .portal-subtitle {
      font-size: 1.1rem;
      color: var(--color-text-secondary);
      margin: 0 0 48px;
    }
    .portal-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 24px;
      max-width: 560px;
      width: 100%;
    }
    .portal-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 32px 28px;
      background: var(--color-surface);
      border: 2px solid var(--color-border);
      border-radius: var(--radius-lg);
      text-decoration: none !important;
      transition: all 0.2s ease;
    }
    .portal-card:hover {
      border-color: var(--color-primary);
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    .portal-card:hover .portal-card-cta {
      color: var(--color-primary);
    }
    .portal-card-icon {
      font-size: 2.5rem;
      margin-bottom: 16px;
    }
    .portal-card-title {
      font-size: 1.35rem;
      font-weight: 700;
      margin: 0 0 8px;
      color: var(--color-text);
    }
    .portal-card-desc {
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      margin: 0 0 16px;
      line-height: 1.5;
    }
    .portal-card-cta {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-text-secondary);
      transition: color 0.2s ease;
    }
    @media (max-width: 640px) {
      .portal-title { font-size: 2rem; }
      .portal-cards { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
