      var text = textInput.value || 'watermark';
      var fontSize = parseInt(sizeInput.value) || 32;
      var color = colorInput.value;
      var opacity = parseFloat(opacitySlider.value);
      var angle = parseInt(rotateSlider.value) * Math.PI / 180;

      wmCtx.save();
      wmCtx.globalAlpha = opacity;
      wmCtx.fillStyle = color;
      wmCtx.font = 'bold ' + fontSize + 'px ' + getComputedStyle(document.body).fontFamily;

      if (tileCb.checked) {
        var stepX = wmCtx.measureText(text).width + fontSize * 4;
        var stepY = fontSize * 5;
        for (var ty = -h; ty < h * 2; ty += stepY) {
          for (var tx = -w; tx < w * 2; tx += stepX) {
            wmCtx.save();
            wmCtx.translate(tx, ty);
            wmCtx.rotate(angle);
            wmCtx.fillText(text, 0, 0);
            wmCtx.restore();
          }
        }
      } else {
        var tw = wmCtx.measureText(text).width;
        var x, y;
        switch (pos) {
          case 'top-left': x = fontSize; y = fontSize * 2; break;
          case 'top-center': x = (w - tw) / 2; y = fontSize * 2; break;
          case 'top-right': x = w - tw - fontSize; y = fontSize * 2; break;
          case 'middle-left': x = fontSize; y = h / 2; break;
          case 'center': x = (w - tw) / 2; y = h / 2; break;
          case 'middle-right': x = w - tw - fontSize; y = h / 2; break;
          case 'bottom-left': x = fontSize; y = h - fontSize; break;
          case 'bottom-center': x = (w - tw) / 2; y = h - fontSize; break;
          case 'bottom-right': x = w - tw - fontSize; y = h - fontSize; break;
          default: x = (w - tw) / 2; y = h / 2;
        }
        wmCtx.save();
        wmCtx.translate(x + tw / 2, y);
        wmCtx.rotate(angle);
        wmCtx.fillText(text, -tw / 2, 0);
        wmCtx.restore();
      }
      wmCtx.restore();
    }

    [textInput, sizeInput, colorInput, tileCb].forEach(function(el) {
      el.addEventListener('input', renderWatermark);
      el.addEventListener('change', renderWatermark);
    });
    opacitySlider.addEventListener('input', function() {
      opacityVal.textContent = parseFloat(opacitySlider.value).toFixed(2);
      renderWatermark();
    });
    rotateSlider.addEventListener('input', function() {
      rotateVal.textContent = rotateSlider.value + '°';
      renderWatermark();
    });
    posCells.forEach(function(cell) {
      cell.addEventListener('click', function() {
        posCells.forEach(function(c) { c.classList.remove('active'); });
        cell.classList.add('active');
        pos = cell.dataset.pos;
        renderWatermark();
      });
    });

    setupUpload('watermark', function(f) {
      loadImage(f, function(i, fi) {
        img = i; file = fi;
        previewArea.classList.remove('hidden');
        controls.classList.remove('hidden');
        actions.classList.remove('hidden');
        renderWatermark();
      });
    });

    document.getElementById('watermark-download').addEventListener('click', function() {
      if (!img) return;
      renderWatermark();
      wmCanvas.toBlob(function(blob) {
        downloadBlob(blob, file.name.replace(/\.[^.]+$/, '') + '_watermarked.png');
      }, 'image/png');
    });
  })();

  // ======== Compress ========
  (function() {
    var statsDiv = document.getElementById('compress-stats');
    var origSizeEl = document.getElementById('compress-orig-size');
    var newSizeEl = document.getElementById('compress-new-size');
    var savedEl = document.getElementById('compress-saved');
    var controls = document.getElementById('compress-controls');
    var actions = document.getElementById('compress-actions');
    var previewArea = document.getElementById('compress-preview');
    var resultImg = document.getElementById('compress-result-img');
    var qualitySlider = document.getElementById('compress-quality');
    var qualityVal = document.getElementById('compress-quality-val');
    var formatSelect = document.getElementById('compress-format');
    var img, file;
    var resultBlob = null;

    function doCompress() {
      if (!img) return;
      var canvas = document.getElementById('process-canvas');
      canvas.width = img.naturalWidth;
      canvas.height = img.naturalHeight;
      var ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0);

      var fmt = formatSelect.value;
      if (fmt === 'same') {
        fmt = file.type;
        if (fmt === 'image/bmp' || fmt === 'image/gif') fmt = 'image/png';
      }
      var q = parseFloat(qualitySlider.value);

      canvas.toBlob(function(blob) {
        resultBlob = blob;
        newSizeEl.textContent = formatSize(blob.size);
        var pct = file.size > 0 ? Math.round((1 - blob.size / file.size) * 100) : 0;
        savedEl.textContent = pct > 0 ? pct + '%' : '0%';
        savedEl.className = 'stat-value' + (pct > 0 ? ' saved' : '');
        resultImg.src = URL.createObjectURL(blob);
      }, fmt, q);
    }

    qualitySlider.addEventListener('input', function() {
      qualityVal.textContent = parseFloat(qualitySlider.value).toFixed(2);
      doCompress();
    });
    formatSelect.addEventListener('change', doCompress);

    setupUpload('compress', function(f) {
      loadImage(f, function(i, fi) {
        img = i; file = fi;
        origSizeEl.textContent = formatSize(fi.size);
        statsDiv.classList.remove('hidden');
        controls.classList.remove('hidden');
        actions.classList.remove('hidden');
        previewArea.classList.remove('hidden');
        doCompress();
      });
    });

    document.getElementById('compress-download').addEventListener('click', function() {
      if (!resultBlob) return;
      var ext = mimeToExt(resultBlob.type);
      downloadBlob(resultBlob, file.name.replace(/\.[^.]+$/, '') + '_compressed.' + ext);
    });
  })();

})();
</script>
</BaseLayout>
