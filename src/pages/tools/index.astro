<script is:inline>
(function() {
  'use strict';

  // ======== Tab switching ========
  var tabBtns = document.querySelectorAll('.tab-btn');
  var tabPanels = document.querySelectorAll('.tab-panel');
  tabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      tabBtns.forEach(function(b) { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
      tabPanels.forEach(function(p) { p.classList.remove('active'); });
      btn.classList.add('active');
      btn.setAttribute('aria-selected','true');
      document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
    });
  });

  // ======== Utility ========
  function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1048576).toFixed(2) + ' MB';
  }

  function mimeToExt(mime) {
    var map = {'image/jpeg':'jpg','image/png':'png','image/webp':'webp','image/bmp':'bmp','image/gif':'gif'};
    return map[mime] || 'png';
  }

  function downloadCanvas(canvas, filename) {
    var link = document.createElement('a');
    link.download = filename;
    link.href = canvas.toDataURL('image/png');
    link.click();
  }

  function downloadBlob(blob, filename) {
    var link = document.createElement('a');
    link.download = filename;
    link.href = URL.createObjectURL(blob);
    link.click();
    setTimeout(function() { URL.revokeObjectURL(link.href); }, 1000);
  }

  // ======== Shared state ========
  var loadedImages = {}; // tab -> Image
  var loadedFiles = {};  // tab -> File

  function setupUpload(tabId, onLoad) {
    var uploadZone = document.getElementById(tabId + '-upload');
    var fileInput = document.getElementById(tabId + '-file');

    uploadZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      uploadZone.classList.add('dragover');
    });
    uploadZone.addEventListener('dragleave', function() {
      uploadZone.classList.remove('dragover');
    });
    uploadZone.addEventListener('drop', function(e) {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
      var file = e.dataTransfer.files[0];
      if (file && file.type.startsWith('image/')) onLoad(file);
    });
    fileInput.addEventListener('change', function() {
      if (fileInput.files[0]) onLoad(fileInput.files[0]);
    });
  }

  function loadImage(file, cb) {
    var reader = new FileReader();
    reader.onload = function(e) {
      var img = new Image();
      img.onload = function() { cb(img, file); };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }

  // ======== Format Convert ========
  (function() {
    var origImgEl = document.getElementById('convert-orig-img');
    var origMeta = document.getElementById('convert-orig-meta');
    var previewArea = document.getElementById('convert-preview');
    var controls = document.getElementById('convert-controls');
    var actions = document.getElementById('convert-actions');
    var qualityGroup = document.getElementById('convert-quality-group');
    var qualitySlider = document.getElementById('convert-quality');
    var qualityVal = document.getElementById('convert-quality-val');
    var formatSelect = document.getElementById('convert-format');
    var img, file;

    function updateQualityVisibility() {
      var fmt = formatSelect.value;
      qualityGroup.style.display = (fmt === 'image/jpeg' || fmt === 'image/webp') ? '' : 'none';
    }

    setupUpload('convert', function(f) {
      loadImage(f, function(i, fi) {
        img = i; file = fi;
        origImgEl.src = i.src;
        origMeta.textContent = fi.name + ' | ' + i.naturalWidth + 'x' + i.naturalHeight + ' | ' + formatSize(fi.size);
        previewArea.classList.remove('hidden');
        controls.classList.remove('hidden');
        actions.classList.remove('hidden');
        updateQualityVisibility();
      });
    });

    formatSelect.addEventListener('change', updateQualityVisibility);
    qualitySlider.addEventListener('input', function() {
      qualityVal.textContent = parseFloat(qualitySlider.value).toFixed(2);
    });

    document.getElementById('convert-download').addEventListener('click', function() {
      if (!img) return;
      var canvas = document.getElementById('process-canvas');
      canvas.width = img.naturalWidth;
      canvas.height = img.naturalHeight;
      var ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0);
      var fmt = formatSelect.value;
      var q = (fmt === 'image/jpeg' || fmt === 'image/webp') ? parseFloat(qualitySlider.value) : undefined;
      canvas.toBlob(function(blob) {
        var name = file.name.replace(/\.[^.]+$/, '') + '.' + mimeToExt(fmt);
        downloadBlob(blob, name);
      }, fmt, q);
    });
  })();

  // ======== Crop ========
  (function() {
    var cropArea = document.getElementById('crop-area');
    var cropContainer = document.getElementById('crop-container');
    var cropImg = document.getElementById('crop-img');
    var overlay = document.getElementById('crop-overlay');
    var controls = document.getElementById('crop-controls');
    var actions = document.getElementById('crop-actions');
    var ratioBtns = document.querySelectorAll('#crop-ratios .preset-chip');
    var img, file, naturalW, naturalH, displayW, displayH;
    var cropRect = { x: 0, y: 0, w: 0, h: 0 };
    var aspectRatio = null; // null = free
    var dragging = false, dragStart = { x: 0, y: 0 }, dragMode = 'create';

    function getPos(e) {
      var r = cropContainer.getBoundingClientRect();
      var clientX = e.touches ? e.touches[0].clientX : e.clientX;
      var clientY = e.touches ? e.touches[0].clientY : e.clientY;
      return {
        x: Math.max(0, Math.min(clientX - r.left, displayW)),
        y: Math.max(0, Math.min(clientY - r.top, displayH))
      };
    }

    function updateOverlay() {
      overlay.style.left = cropRect.x + 'px';
      overlay.style.top = cropRect.y + 'px';
      overlay.style.width = cropRect.w + 'px';
      overlay.style.height = cropRect.h + 'px';
    }

    function applyAspect() {
      if (aspectRatio && cropRect.w > 0) {
        cropRect.h = cropRect.w / aspectRatio;
        if (cropRect.y + cropRect.h > displayH) {
          cropRect.h = displayH - cropRect.y;
          cropRect.w = cropRect.h * aspectRatio;
        }
        if (cropRect.x + cropRect.w > displayW) {
          cropRect.w = displayW - cropRect.x;
          cropRect.h = cropRect.w / aspectRatio;
        }
      }
    }

    cropContainer.addEventListener('mousedown', function(e) {
      e.preventDefault();
      var pos = getPos(e);
      dragging = true;
      dragStart = pos;
      cropRect = { x: pos.x, y: pos.y, w: 0, h: 0 };
      dragMode = 'create';
      updateOverlay();
    });
    cropContainer.addEventListener('touchstart', function(e) {
      e.preventDefault();
      var pos = getPos(e);
      dragging = true;
      dragStart = pos;
      cropRect = { x: pos.x, y: pos.y, w: 0, h: 0 };
      dragMode = 'create';
      updateOverlay();
    }, { passive: false });

    function onMove(e) {
      if (!dragging) return;
      e.preventDefault();
      var pos = getPos(e);
      var w = pos.x - dragStart.x;
      var h = pos.y - dragStart.y;
      if (w >= 0) { cropRect.x = dragStart.x; cropRect.w = w; }
      else { cropRect.x = pos.x; cropRect.w = -w; }
      if (h >= 0) { cropRect.y = dragStart.y; cropRect.h = h; }
      else { cropRect.y = pos.y; cropRect.h = -h; }
      applyAspect();
      updateOverlay();
    }
    function onEnd() { dragging = false; }

    document.addEventListener('mousemove', onMove);
    document.addEventListener('touchmove', onMove, { passive: false });
    document.addEventListener('mouseup', onEnd);
    document.addEventListener('touchend', onEnd);

    ratioBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        ratioBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var r = btn.dataset.ratio;
        if (r === 'free') { aspectRatio = null; }
        else {
          var parts = r.split(':');
          aspectRatio = parseInt(parts[0]) / parseInt(parts[1]);
        }
        if (cropRect.w > 0) {
          applyAspect();
          updateOverlay();
        }
      });
    });

    document.getElementById('crop-reset').addEventListener('click', function() {
      cropRect = { x: 0, y: 0, w: 0, h: 0 };
      updateOverlay();
    });

    setupUpload('crop', function(f) {
      loadImage(f, function(i, fi) {
        img = i; file = fi;
        naturalW = i.naturalWidth; naturalH = i.naturalHeight;
        cropImg.src = i.src;
        cropImg.onload = function() {
          displayW = cropImg.clientWidth;
          displayH = cropImg.clientHeight;
        };
        cropArea.classList.remove('hidden');
        controls.classList.remove('hidden');
        actions.classList.remove('hidden');
        cropRect = { x: 0, y: 0, w: 0, h: 0 };
        updateOverlay();
      });
    });

    document.getElementById('crop-download').addEventListener('click', function() {
      if (!img || cropRect.w < 2 || cropRect.h < 2) return;
      var scaleX = naturalW / displayW;
      var scaleY = naturalH / displayH;
      var sx = Math.round(cropRect.x * scaleX);
      var sy = Math.round(cropRect.y * scaleY);
      var sw = Math.round(cropRect.w * scaleX);
      var sh = Math.round(cropRect.h * scaleY);
      var canvas = document.getElementById('process-canvas');
      canvas.width = sw; canvas.height = sh;
      var ctx = canvas.getContext('2d');
      ctx.drawImage(img, sx, sy, sw, sh, 0, 0, sw, sh);
      canvas.toBlob(function(blob) {
        downloadBlob(blob, file.name.replace(/\.[^.]+$/, '') + '_cropped.png');
      }, 'image/png');
    });
  })();

  // ======== Resize ========
  (function() {
    var origImgEl = document.getElementById('resize-orig-img');
    var origMeta = document.getElementById('resize-orig-meta');
    var previewArea = document.getElementById('resize-preview');
    var controls = document.getElementById('resize-controls');
    var actions = document.getElementById('resize-actions');
    var wInput = document.getElementById('resize-width');
    var hInput = document.getElementById('resize-height');
    var lockCb = document.getElementById('resize-lock');
    var presetBtns = document.querySelectorAll('#resize-presets .preset-chip');
    var img, file, ratio = 1;

    function syncFromWidth() {
      if (lockCb.checked) {
        hInput.value = Math.round(parseInt(wInput.value) / ratio) || '';
      }
    }
    function syncFromHeight() {
      if (lockCb.checked) {
        wInput.value = Math.round(parseInt(hInput.value) * ratio) || '';
      }
    }
    wInput.addEventListener('input', syncFromWidth);
    hInput.addEventListener('input', syncFromHeight);

    presetBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        presetBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        wInput.value = btn.dataset.w;
        if (lockCb.checked) {
          hInput.value = Math.round(parseInt(btn.dataset.w) / ratio) || btn.dataset.h;
        } else {
          hInput.value = btn.dataset.h;
        }
      });
    });

    setupUpload('resize', function(f) {
      loadImage(f, function(i, fi) {
        img = i; file = fi;
        ratio = i.naturalWidth / i.naturalHeight;
        origImgEl.src = i.src;
        origMeta.textContent = fi.name + ' | ' + i.naturalWidth + 'x' + i.naturalHeight + ' | ' + formatSize(fi.size);
        wInput.value = i.naturalWidth;
        hInput.value = i.naturalHeight;
        previewArea.classList.remove('hidden');
        controls.classList.remove('hidden');
        actions.classList.remove('hidden');
      });
    });

    document.getElementById('resize-download').addEventListener('click', function() {
      if (!img) return;
      var w = parseInt(wInput.value) || img.naturalWidth;
      var h = parseInt(hInput.value) || img.naturalHeight;
      var canvas = document.getElementById('process-canvas');
      canvas.width = w; canvas.height = h;
      var ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, w, h);
      canvas.toBlob(function(blob) {
        downloadBlob(blob, file.name.replace(/\.[^.]+$/, '') + '_' + w + 'x' + h + '.png');
      }, 'image/png');
    });
  })();

  // ======== Watermark ========
  (function() {
    var wmCanvas = document.getElementById('watermark-canvas');
    var wmCtx = wmCanvas.getContext('2d');
    var previewArea = document.getElementById('watermark-preview');
