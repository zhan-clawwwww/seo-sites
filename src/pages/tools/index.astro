---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = '图片处理百宝箱 - 免费在线图片压缩、格式转换、加水印 | wordok.top';
const description = '免费在线图片处理工具箱：支持图片压缩、格式转换（PNG/JPG/WEBP/BMP/GIF互转）、图片裁切、尺寸调整、添加文字水印。纯浏览器本地处理，图片不上传服务器，安全快捷。';
const canonical = 'https://wordok.top/tools/';
const keywords = [
  '图片压缩', '在线图片处理', '图片格式转换', '图片加水印', '图片裁切',
  '尺寸调整', 'PNG转JPG', '图片处理工具', '在线图片编辑', '免费图片工具',
  'WEBP转换', '图片批量处理', '在线裁剪图片', '图片缩放'
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "图片处理百宝箱",
  "url": "https://wordok.top/tools/",
  "description": description,
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "CNY"
  },
  "featureList": [
    "图片格式转换",
    "图片裁切",
    "尺寸调整",
    "文字水印",
    "图片压缩"
  ]
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "图片处理百宝箱支持哪些格式？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "支持 PNG、JPG/JPEG、WEBP、BMP、GIF 五种常见图片格式的互转，以及裁切、缩放、加水印和压缩操作。"
      }
    },
    {
      "@type": "Question",
      "name": "图片会被上传到服务器吗？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "不会。所有图片处理均在浏览器本地通过 Canvas API 完成，图片不会离开您的设备，完全保护隐私。"
      }
    },
    {
      "@type": "Question",
      "name": "如何压缩图片大小？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "选择「图片压缩」标签页，上传图片后调节压缩质量滑块（0.1-1.0），系统会实时显示压缩前后文件大小对比，满意后点击下载即可。"
      }
    }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  keywords={keywords}
  jsonLd={[jsonLd, faqJsonLd]}
  openGraph={{
    type: "website",
    title: "图片处理百宝箱 - 免费在线图片处理工具",
    description: description,
    url: canonical,
    siteName: "wordok.top",
    image: "https://wordok.top/og-default.png",
    locale: "zh_CN"
  }}
  twitter={{
    card: "summary_large_image",
    title: "图片处理百宝箱 - 免费在线图片处理",
    description: description,
    image: "https://wordok.top/og-default.png",
    site: "@wordok_top"
  }}
>
<style>
  /* ===== Tools Page Styles ===== */
  .tools-nav {
    display: flex;
    align-items: center;
    gap: 6px 14px;
    flex-wrap: wrap;
    font-size: 0.85rem;
    margin-bottom: 28px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-border);
  }
  .tools-nav a {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition);
    white-space: nowrap;
  }
  .tools-nav a:hover { color: var(--color-primary); text-decoration: none; }
  .tools-nav .sep { color: var(--color-border); }

  .tools-hero {
    text-align: center;
    margin-bottom: 36px;
  }
  .tools-hero h1 {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.3;
    margin: 0 0 10px;
    background: var(--gradient-title);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .tools-hero p {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 560px;
    margin-inline: auto;
  }

  /* Tabs */
  .tabs-nav {
    display: flex;
    gap: 4px;
    border-bottom: 2px solid var(--color-border);
    margin-bottom: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }
  .tabs-nav::-webkit-scrollbar { display: none; }
  .tab-btn {
    flex: 0 0 auto;
    padding: 10px 20px;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition), border-color var(--transition);
    scroll-snap-align: start;
    min-height: 44px;
    font-family: var(--font-sans);
  }
  .tab-btn:hover { color: var(--color-primary); }
  .tab-btn.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .tab-panel { display: none; padding: 28px 0; }
  .tab-panel.active { display: block; }

  /* Upload zone */
  .upload-zone {
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    padding: 48px 24px;
    text-align: center;
    cursor: pointer;
    transition: border-color var(--transition), background var(--transition);
    background: var(--color-surface);
    position: relative;
  }
  .upload-zone:hover,
  .upload-zone.dragover {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 5%, transparent);
  }
  .upload-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
  .upload-icon {
    font-size: 2.5rem;
    margin-bottom: 12px;
    opacity: 0.6;
  }
  .upload-zone p {
    color: var(--color-text-secondary);
    margin: 4px 0;
    font-size: 0.95rem;
  }
  .upload-zone .hint {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    opacity: 0.7;
  }

  /* Preview area */
  .preview-area {
    display: flex;
    gap: 20px;
    margin-top: 20px;
    flex-wrap: wrap;
  }
  .preview-box {
    flex: 1;
    min-width: 200px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 16px;
    text-align: center;
  }
  .preview-box h3 {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    margin: 0 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .preview-box img, .preview-box canvas {
    max-width: 100%;
    max-height: 300px;
    border-radius: var(--radius);
    object-fit: contain;
  }
  .preview-box .meta {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    margin-top: 8px;
  }

  /* Controls */
  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: flex-end;
    margin-top: 20px;
    padding: 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .control-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 120px;
  }
  .control-group label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }
  .control-group select,
  .control-group input[type="number"],
  .control-group input[type="text"],
  .control-group input[type="color"] {
    padding: 8px 12px;
    font-size: 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    min-height: 40px;
    box-sizing: border-box;
  }
  .control-group input[type="range"] {
    width: 100%;
    min-width: 140px;
    accent-color: var(--color-primary);
  }
  .control-group input[type="color"] {
    width: 50px;
    height: 40px;
    padding: 4px;
    cursor: pointer;
  }
  .control-group .range-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .control-group .range-val {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    min-width: 36px;
    text-align: right;
  }
  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    cursor: pointer;
    min-height: 40px;
  }
  .checkbox-label input[type="checkbox"] {
    accent-color: var(--color-primary);
    width: 18px;
    height: 18px;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 22px;
    font-size: 0.9rem;
    font-weight: 600;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition: background var(--transition), transform var(--transition);
    font-family: var(--font-sans);
    min-height: 44px;
    text-decoration: none !important;
  }
  .btn:active { transform: scale(0.97); }
  .btn-primary {
    background: var(--color-primary);
    color: #fff;
  }
  .btn-primary:hover { background: var(--color-primary-hover); color: #fff; }
  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-secondary:hover { background: var(--color-surface-hover); }
  .btn-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 20px;
  }

  /* Size presets */
  .preset-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 6px;
  }
  .preset-chip {
    padding: 5px 12px;
    font-size: 0.78rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: 99px;
    background: var(--color-bg);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--transition);
    font-family: var(--font-sans);
    white-space: nowrap;
  }
  .preset-chip:hover,
  .preset-chip.active {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  /* Crop area */
  .crop-container {
    position: relative;
    display: inline-block;
    max-width: 100%;
    overflow: hidden;
    border-radius: var(--radius);
    cursor: crosshair;
    user-select: none;
    -webkit-user-select: none;
  }
  .crop-container img {
    display: block;
    max-width: 100%;
    max-height: 500px;
    object-fit: contain;
    pointer-events: none;
  }
  .crop-overlay {
    position: absolute;
    border: 2px dashed var(--color-primary);
    background: rgba(124, 58, 237, 0.1);
    box-shadow: 0 0 0 9999px rgba(0,0,0,0.3);
    pointer-events: none;
  }
  .crop-handle {
    position: absolute;
    width: 12px;
    height: 12px;
    background: var(--color-primary);
    border: 2px solid #fff;
    border-radius: 50%;
    pointer-events: auto;
    cursor: nwse-resize;
    z-index: 2;
  }
  .crop-handle.tl { top: -6px; left: -6px; cursor: nwse-resize; }
  .crop-handle.tr { top: -6px; right: -6px; cursor: nesw-resize; }
  .crop-handle.bl { bottom: -6px; left: -6px; cursor: nesw-resize; }
  .crop-handle.br { bottom: -6px; right: -6px; cursor: nwse-resize; }

  /* Compression stats */
  .compress-stats {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-top: 16px;
    padding: 16px 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .stat-item {
    text-align: center;
    flex: 1;
    min-width: 100px;
  }
  .stat-item .stat-label {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }
  .stat-item .stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 4px;
  }
  .stat-item .stat-value.saved {
    color: #16a34a;
  }

  /* SEO content section */
  .seo-section {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }
  .seo-section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 16px;
  }
  .seo-section h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 1.5em 0 0.5em;
  }
  .seo-section p {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin: 0.6em 0;
  }
  .seo-section ul {
    padding-left: 1.5em;
    color: var(--color-text-secondary);
  }
  .seo-section li {
    margin: 0.3em 0;
    line-height: 1.7;
  }

  /* Ad container */
  #ad-container {
    min-height: 90px;
    margin: 40px auto;
    text-align: center;
    max-width: 728px;
  }

  /* Footer links */
  .tools-footer {
    margin-top: 32px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 0.85rem;
    justify-content: center;
  }
  .tools-footer a {
    color: var(--color-text-secondary);
  }
  .tools-footer a:hover {
    color: var(--color-primary);
  }

  /* Watermark position grid */
  .pos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    width: 100px;
  }
  .pos-cell {
    width: 100%;
    aspect-ratio: 1.6;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-bg);
    cursor: pointer;
    transition: all var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
  }
  .pos-cell:hover { border-color: var(--color-primary); }
  .pos-cell.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  /* Hidden canvas for processing */
  .hidden { display: none; }

  /* Responsive */
  @media (max-width: 640px) {
    .tools-hero h1 { font-size: 1.5rem; }
    .tools-hero p { font-size: 0.92rem; }
    .tab-btn { padding: 10px 14px; font-size: 0.82rem; }
    .controls { padding: 14px; gap: 12px; }
    .control-group { min-width: 100%; }
    .preview-area { flex-direction: column; }
    .compress-stats { gap: 12px; }
    .stat-item .stat-value { font-size: 1.1rem; }
    .upload-zone { padding: 32px 16px; }
  }
</style>

<!-- Navigation -->
<nav class="tools-nav" aria-label="工具箱导航">
  <a href="/">首页</a>
  <span class="sep">/</span>
  <a href="/tools/" aria-current="page"><strong>工具箱</strong></a>
  <span class="sep">/</span>
  <a href="/tools/about/">关于</a>
  <span class="sep">/</span>
  <a href="/tools/privacy/">隐私政策</a>
  <span class="sep">/</span>
  <a href="/tools/contact/">联系</a>
</nav>

<!-- Hero -->
<div class="tools-hero">
  <h1>图片处理百宝箱</h1>
  <p>免费在线图片压缩、格式转换、裁切、缩放、加水印 — 全部在浏览器本地完成，图片不上传服务器</p>
</div>

<!-- Tab Navigation -->
<div class="tabs-nav" role="tablist">
  <button class="tab-btn active" role="tab" data-tab="convert" aria-selected="true">格式转换</button>
  <button class="tab-btn" role="tab" data-tab="crop" aria-selected="false">图片裁切</button>
  <button class="tab-btn" role="tab" data-tab="resize" aria-selected="false">尺寸调整</button>
  <button class="tab-btn" role="tab" data-tab="watermark" aria-selected="false">加水印</button>
  <button class="tab-btn" role="tab" data-tab="compress" aria-selected="false">图片压缩</button>
</div>

<!-- ==================== 格式转换 ==================== -->
<div class="tab-panel active" id="panel-convert" role="tabpanel">
  <h2>在线图片格式转换</h2>
  <div class="upload-zone" id="convert-upload">
    <input type="file" accept="image/png,image/jpeg,image/webp,image/bmp,image/gif" id="convert-file" />
    <div class="upload-icon">&#128444;</div>
    <p>拖拽图片到此处，或 <strong>点击选择文件</strong></p>
    <p class="hint">支持 PNG、JPG、WEBP、BMP、GIF 格式</p>
  </div>
  <div id="convert-preview" class="preview-area hidden">
    <div class="preview-box">
      <h3>原图</h3>
      <img id="convert-orig-img" alt="原图预览" />
      <div class="meta" id="convert-orig-meta"></div>
    </div>
  </div>
  <div id="convert-controls" class="controls hidden">
    <div class="control-group">
      <label for="convert-format">目标格式</label>
      <select id="convert-format">
        <option value="image/jpeg">JPG</option>
        <option value="image/png">PNG</option>
        <option value="image/webp">WEBP</option>
        <option value="image/bmp">BMP</option>
        <option value="image/gif">GIF</option>
      </select>
    </div>
    <div class="control-group" id="convert-quality-group">
      <label>JPG/WEBP 质量</label>
      <div class="range-row">
        <input type="range" id="convert-quality" min="0.1" max="1" step="0.05" value="0.92" />
        <span class="range-val" id="convert-quality-val">0.92</span>
      </div>
    </div>
  </div>
  <div id="convert-actions" class="btn-row hidden">
    <button class="btn btn-primary" id="convert-download">下载转换结果</button>
  </div>
</div>

<!-- ==================== 图片裁切 ==================== -->
<div class="tab-panel" id="panel-crop" role="tabpanel">
  <h2>在线图片裁切工具</h2>
  <div class="upload-zone" id="crop-upload">
    <input type="file" accept="image/png,image/jpeg,image/webp,image/bmp,image/gif" id="crop-file" />
    <div class="upload-icon">&#9988;</div>
    <p>拖拽图片到此处，或 <strong>点击选择文件</strong></p>
    <p class="hint">支持 PNG、JPG、WEBP、BMP、GIF 格式</p>
  </div>
  <div id="crop-controls" class="controls hidden">
    <div class="control-group">
      <label>裁切比例</label>
      <div class="preset-chips" id="crop-ratios">
        <button class="preset-chip active" data-ratio="free">自由</button>
        <button class="preset-chip" data-ratio="1:1">1:1</button>
        <button class="preset-chip" data-ratio="4:3">4:3</button>
        <button class="preset-chip" data-ratio="16:9">16:9</button>
        <button class="preset-chip" data-ratio="3:4">3:4</button>
      </div>
    </div>
  </div>
  <div id="crop-area" class="hidden" style="margin-top:20px;">
    <div class="crop-container" id="crop-container">
      <img id="crop-img" alt="裁切预览" />
      <div class="crop-overlay" id="crop-overlay"></div>
    </div>
  </div>
  <div id="crop-actions" class="btn-row hidden">
    <button class="btn btn-primary" id="crop-download">下载裁切结果</button>
    <button class="btn btn-secondary" id="crop-reset">重置选区</button>
  </div>
</div>

<!-- ==================== 尺寸调整 ==================== -->
<div class="tab-panel" id="panel-resize" role="tabpanel">
  <h2>在线图片尺寸调整</h2>
  <div class="upload-zone" id="resize-upload">
    <input type="file" accept="image/png,image/jpeg,image/webp,image/bmp,image/gif" id="resize-file" />
    <div class="upload-icon">&#8644;</div>
    <p>拖拽图片到此处，或 <strong>点击选择文件</strong></p>
    <p class="hint">支持 PNG、JPG、WEBP、BMP、GIF 格式</p>
  </div>
  <div id="resize-preview" class="preview-area hidden">
    <div class="preview-box">
      <h3>原图</h3>
      <img id="resize-orig-img" alt="原图预览" />
      <div class="meta" id="resize-orig-meta"></div>
    </div>
  </div>
  <div id="resize-controls" class="controls hidden">
    <div class="control-group">
      <label for="resize-width">宽度 (px)</label>
      <input type="number" id="resize-width" min="1" max="10000" placeholder="宽度" />
    </div>
    <div class="control-group">
      <label class="checkbox-label">
        <input type="checkbox" id="resize-lock" checked />
        锁定比例
      </label>
    </div>
    <div class="control-group">
      <label for="resize-height">高度 (px)</label>
      <input type="number" id="resize-height" min="1" max="10000" placeholder="高度" />
    </div>
    <div class="control-group">
