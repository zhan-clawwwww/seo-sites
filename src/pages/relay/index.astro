---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveRootSiteAnalytics } from "../../lib/root-analytics";
import { getPublicRootBaseUrl } from "../../lib/root-base-url";
import { getAllSites, getSiteConfig, toCanonical } from "../../lib/site-data";

const firstSite = getAllSites()[0];
const rootAnalytics = resolveRootSiteAnalytics(
  firstSite ? getSiteConfig(firstSite.slug)?.analytics : undefined,
);
const rootBaseUrl = getPublicRootBaseUrl();
const canonical = toCanonical(rootBaseUrl, "/relay/");
const relayOrigin = (import.meta.env.PUBLIC_RELAY_URL as string | undefined)?.replace(/\/$/, "") ?? "https://relay.wordok.top";
---

<BaseLayout
  title="Token API 中转 — wordok.top"
  description="使用自有 API Key 通过 relay.wordok.top 转发调用 OpenAI、Anthropic、Gemini；零服务端密钥成本，配套推广链接与文档。"
  canonical={canonical}
  keywords={["OpenAI API", "Claude API", "Gemini API", "API 中转", "relay"]}
  analytics={rootAnalytics}
  hasAffiliates={true}
>
  <main class="relay-page">
    <header class="relay-hero">
      <h1>Token API 中转</h1>
      <p class="relay-lead">
        在 <strong>{relayOrigin}</strong> 上转发你的自有 Key，不经过我们代付；适合开发者自用与推广场景。主站 SEO 内容不受影响。
      </p>
    </header>

    <section class="relay-section" aria-labelledby="how-h">
      <h2 id="how-h">工作原理</h2>
      <ol>
        <li>在下方提交你的 OpenAI / Anthropic / Gemini Key，获得一个 <code>relay token</code>。</li>
        <li>客户端请求发往 <code>{relayOrigin}</code>，在 <code>Authorization: Bearer &lt;relay token&gt;</code> 中携带该 token。</li>
        <li>Worker 将请求转发到对应上游，响应（含 SSE 流式）原样返回。</li>
      </ol>
    </section>

    <section class="relay-section" aria-labelledby="form-h">
      <h2 id="form-h">注册 relay token</h2>
      <p class="relay-note">Key 仅存于 Cloudflare KV；请勿在公共仓库提交 token。</p>
      <form class="relay-form" id="relay-register">
        <label>
          Provider
          <select name="provider" required>
            <option value="openai">OpenAI（sk-…）</option>
            <option value="anthropic">Anthropic（sk-ant-…）</option>
            <option value="gemini">Google Gemini</option>
          </select>
        </label>
        <label>
          API Key
          <input name="apiKey" type="password" autocomplete="off" required minlength="10" placeholder="你的上游 Key" />
        </label>
        <label>
          推广码（可选）
          <input name="refCode" type="text" pattern="[A-Za-z0-9]{4,16}" placeholder="访问带 ?ref= 的链接时填写" />
        </label>
        <button type="submit">生成 relay token</button>
      </form>
      <pre class="relay-result" id="relay-result" hidden></pre>
    </section>

    <section class="relay-section" aria-labelledby="doc-h">
      <h2 id="doc-h">文档与推广</h2>
      <ul>
        <li><a href={toCanonical(rootBaseUrl, "/relay/docs/")}>API 与路径说明</a></li>
        <li>盈利与推广思路见仓库 <code>token-relay/README.md</code>（联盟链接需自行替换 Worker 内占位符）。</li>
      </ul>
    </section>
  </main>
</BaseLayout>

<script define:vars={{ relayOrigin }}>
  const form = document.getElementById("relay-register");
  const out = document.getElementById("relay-result");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(form as HTMLFormElement);
    const body = {
      provider: String(fd.get("provider") || ""),
      apiKey: String(fd.get("apiKey") || ""),
      refCode: (fd.get("refCode") as string)?.trim() || undefined,
    };
    const urlParams = new URLSearchParams(window.location.search);
    const refFromUrl = urlParams.get("ref");
    if (refFromUrl && !body.refCode) body.refCode = refFromUrl;

    out?.removeAttribute("hidden");
    out!.textContent = "请求中…";
    try {
      const res = await fetch(`${relayOrigin}/api/keys/submit`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const text = await res.text();
      out!.textContent = text;
    } catch (err) {
      out!.textContent = String(err);
    }
  });
</script>

<style>
  .relay-page {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }
  .relay-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: 0.75rem;
  }
  .relay-lead {
    color: var(--muted, #5c5c5c);
    line-height: 1.6;
  }
  .relay-section {
    margin-top: 2rem;
  }
  .relay-section h2 {
    font-size: 1.15rem;
    margin-bottom: 0.75rem;
  }
  .relay-section ol,
  .relay-section ul {
    padding-left: 1.25rem;
    line-height: 1.65;
  }
  .relay-note {
    font-size: 0.9rem;
    color: var(--muted, #666);
    margin-bottom: 0.75rem;
  }
  .relay-form {
    display: grid;
    gap: 0.85rem;
  }
  .relay-form label {
    display: grid;
    gap: 0.35rem;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .relay-form input,
  .relay-form select,
  .relay-form button {
    font: inherit;
    padding: 0.5rem 0.65rem;
  }
  .relay-form button {
    cursor: pointer;
    justify-self: start;
  }
  .relay-result {
    margin-top: 1rem;
    padding: 1rem;
    overflow: auto;
    background: rgba(0, 0, 0, 0.04);
    border-radius: 6px;
    white-space: pre-wrap;
    word-break: break-all;
  }
</style>
