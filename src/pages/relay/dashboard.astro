---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveRootSiteAnalytics } from "../../lib/root-analytics";
import { getPublicRootBaseUrl } from "../../lib/root-base-url";
import { getAllSites, getSiteConfig, toCanonical } from "../../lib/site-data";

const firstSite = getAllSites()[0];
const rootAnalytics = resolveRootSiteAnalytics(
  firstSite ? getSiteConfig(firstSite.slug)?.analytics : undefined,
);
const rootBaseUrl = getPublicRootBaseUrl();
const canonical = toCanonical(rootBaseUrl, "/relay/dashboard/");
const relayOrigin = (import.meta.env.PUBLIC_RELAY_URL as string | undefined)?.replace(/\/$/, "") ?? "https://relay.wordok.top";
---

<BaseLayout
  title="Relay 控制台 — wordok.top"
  description="查看推广统计（本地浏览器输入 relay token，不上传服务器）。"
  canonical={canonical}
  analytics={rootAnalytics}
  robots="noindex, nofollow"
>
  <main class="relay-dash">
    <h1>Relay 控制台</h1>
    <p class="muted">Token 仅保存在本机浏览器内存，不会写入 Astro 静态站。</p>

    <label>
      Relay token
      <input id="relay-token" type="password" autocomplete="off" class="relay-input" />
    </label>

    <div class="relay-actions">
      <button type="button" id="btn-create-ref">创建推广码</button>
      <button type="button" id="btn-stats">刷新统计</button>
    </div>

    <pre id="relay-out" class="relay-out"></pre>

    <p><a href={toCanonical(rootBaseUrl, "/relay/")}>← 返回</a></p>
  </main>
</BaseLayout>

<script define:vars={{ relayOrigin }}>
  const tokenEl = document.getElementById("relay-token") as HTMLInputElement | null;
  const out = document.getElementById("relay-out");

  async function authFetch(path: string, method: string) {
    const token = tokenEl?.value?.trim();
    if (!token) {
      out!.textContent = "请先填写 relay token";
      return;
    }
    out!.textContent = "请求中…";
    const res = await fetch(`${relayOrigin}${path}`, {
      method,
      headers: { Authorization: `Bearer ${token}` },
    });
    out!.textContent = await res.text();
  }

  document.getElementById("btn-create-ref")?.addEventListener("click", () => {
    void authFetch("/api/ref/create", "POST");
  });
  document.getElementById("btn-stats")?.addEventListener("click", () => {
    void authFetch("/api/ref/stats", "GET");
  });
</script>

<style>
  .relay-dash {
    max-width: 40rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }
  .muted {
    color: var(--muted, #666);
    margin-bottom: 1rem;
  }
  .relay-input {
    width: 100%;
    font: inherit;
    padding: 0.5rem 0.65rem;
    margin-top: 0.35rem;
  }
  .relay-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .relay-out {
    margin-top: 1rem;
    padding: 1rem;
    min-height: 4rem;
    background: rgba(0, 0, 0, 0.04);
    border-radius: 6px;
    white-space: pre-wrap;
    word-break: break-all;
  }
</style>
