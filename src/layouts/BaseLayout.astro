---
import { getAllSites } from "../lib/site-data";

// Short labels for cross-channel nav
const CHANNEL_LABELS: Record<string, string> = {
  "vpn-usa": "VPN",
  ai: "AI News",
  apple: "Apple",
};

type Props = {
  title: string;
  description?: string;
  canonical: string;
  keywords?: string[];
  openGraph?: {
    type?: "website" | "article";
    title?: string;
    description?: string;
    url?: string;
    siteName?: string;
    image?: string;
    locale?: string;
    publishedTime?: string;
    modifiedTime?: string;
    tags?: string[];
  };
  twitter?: {
    card?: "summary" | "summary_large_image";
    title?: string;
    description?: string;
    image?: string;
    site?: string;
    creator?: string;
  };
  jsonLd?: unknown | unknown[];
  siteSlug?: string;
  siteName?: string;
  siteDescription?: string;
  lang?: string;
  analytics?: {
    ga4Id?: string;
    cfBeacon?: string;
  };
  adsense?: {
    publisherId?: string;
    adSlot?: string;
  };
  hasAffiliates?: boolean;
};

const {
  title,
  description,
  canonical,
  keywords,
  openGraph,
  twitter,
  jsonLd,
  siteSlug,
  siteName,
  siteDescription,
  lang,
  analytics,
  adsense,
  hasAffiliates,
} = Astro.props;

function toJsonLdArray(v: unknown | unknown[] | undefined): unknown[] {
  if (!v) return [];
  return Array.isArray(v) ? v : [v];
}

function safeJsonStringify(v: unknown): string {
  return JSON.stringify(v).replace(/<\/script/gi, "<\\/script");
}

const currentYear = new Date().getFullYear();

const allSites = getAllSites();
const otherChannels = siteSlug
  ? allSites.filter((s) => s.slug !== siteSlug)
  : allSites;
---

<!doctype html>
<html lang={lang || "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {keywords?.length ? (
      <meta name="keywords" content={keywords.join(",")} />
    ) : null}
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap_index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/og-default.png" />

    {/* RSS Autodiscovery */}
    {siteSlug ? (
      <link
        rel="alternate"
        type="application/rss+xml"
        title={siteName ? `${siteName} RSS Feed` : "RSS Feed"}
        href={`/${siteSlug}/rss.xml`}
      />
    ) : null}

    {/* Preconnect for performance */}
    {analytics?.ga4Id ? (
      <link rel="preconnect" href="https://www.googletagmanager.com" />
    ) : null}
    {adsense?.publisherId ? (
      <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
    ) : null}

    {/* Google AdSense */}
    {adsense?.publisherId ? (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsense.publisherId}`}
        crossorigin="anonymous"
      ></script>
    ) : null}

    {/* OpenGraph */}
    {openGraph?.title ? <meta property="og:title" content={openGraph.title} /> : null}
    {openGraph?.description ? (
      <meta property="og:description" content={openGraph.description} />
    ) : null}
    <meta property="og:url" content={openGraph?.url ?? canonical} />
    <meta property="og:type" content={openGraph?.type ?? "website"} />
    {openGraph?.siteName ? <meta property="og:site_name" content={openGraph.siteName} /> : null}
    {openGraph?.locale ? <meta property="og:locale" content={openGraph.locale} /> : null}
    {openGraph?.image ? (
      <>
        <meta property="og:image" content={openGraph.image} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    ) : null}
    {openGraph?.publishedTime ? (
      <meta property="article:published_time" content={openGraph.publishedTime} />
    ) : null}
    {openGraph?.modifiedTime ? (
      <meta property="article:modified_time" content={openGraph.modifiedTime} />
    ) : null}
    {openGraph?.tags?.length
      ? openGraph.tags.map((t) => <meta property="article:tag" content={t} />)
      : null}

    {/* Twitter Card */}
    {twitter ? <meta name="twitter:card" content={twitter.card ?? "summary"} /> : null}
    {twitter?.title ? <meta name="twitter:title" content={twitter.title} /> : null}
    {twitter?.description ? (
      <meta name="twitter:description" content={twitter.description} />
    ) : null}
    {twitter?.image ? <meta name="twitter:image" content={twitter.image} /> : null}
    {twitter?.site ? <meta name="twitter:site" content={twitter.site} /> : null}
    {twitter?.creator ? <meta name="twitter:creator" content={twitter.creator} /> : null}

    {/* JSON-LD */}
    {toJsonLdArray(jsonLd).map((obj) => (
      <script type="application/ld+json" set:html={safeJsonStringify(obj)} />
    ))}

    {/* Google Analytics 4 */}
    {analytics?.ga4Id ? (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${analytics.ga4Id}`}></script>
    ) : null}
    {analytics?.ga4Id ? (
      <script define:vars={{ gaId: analytics.ga4Id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(...args: any[]) { window.dataLayer.push(args); }
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    ) : null}

    {/* Cloudflare Web Analytics */}
    {analytics?.cfBeacon ? (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${analytics.cfBeacon}"}`}
      ></script>
    ) : null}

    <style is:global>
      /* === Design System === */
      :root {
        --color-bg: #ffffff;
        --color-surface: #f8f9fa;
        --color-surface-hover: #f0f1f3;
        --color-border: #e2e8f0;
        --color-text: #1a202c;
        --color-text-secondary: #64748b;
        --color-primary: #2563eb;
        --color-primary-hover: #1d4ed8;
        --color-accent: #7c3aed;
        --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        --font-mono: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
        --container-max: 860px;
        --radius: 8px;
        --radius-lg: 12px;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
        --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
        --transition: 0.2s ease;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --color-bg: #0f172a;
          --color-surface: #1e293b;
          --color-surface-hover: #263448;
          --color-border: #334155;
          --color-text: #e2e8f0;
          --color-text-secondary: #94a3b8;
          --color-primary: #60a5fa;
          --color-primary-hover: #93bbfc;
        }
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; }
      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font-sans);
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: var(--color-primary);
        text-decoration: none;
        transition: color var(--transition);
      }
      a:hover {
        color: var(--color-primary-hover);
        text-decoration: underline;
      }

      img { max-width: 100%; height: auto; }

      /* === Site Header === */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
        padding: 0;
      }
      @media (prefers-color-scheme: dark) {
        .site-header {
          background: rgba(15,23,42,0.85);
        }
      }
      .header-inner {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 12px 24px;
        display: flex;
        align-items: center;
        gap: 24px;
        flex-wrap: wrap;
      }
      .site-logo {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--color-text) !important;
        text-decoration: none !important;
        white-space: nowrap;
      }
      .site-nav {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
      }
      .site-nav a {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--color-text-secondary);
        text-decoration: none;
        padding: 4px 0;
        border-bottom: 2px solid transparent;
        transition: color var(--transition), border-color var(--transition);
      }
      .site-nav a:hover {
        color: var(--color-primary);
        border-bottom-color: var(--color-primary);
        text-decoration: none;
      }
      .header-search {
        margin-left: auto;
      }
      .header-search .pagefind-ui {
        --pagefind-ui-scale: 0.8;
      }
      .header-search .pagefind-ui__search-input {
        max-width: 200px;
      }

      /* === Container === */
      .container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 24px;
        width: 100%;
      }

      /* === Main Content === */
      .main-content {
        flex: 1;
        padding: 32px 24px;
        max-width: var(--container-max);
        margin: 0 auto;
        width: 100%;
      }

      /* === Article Typography === */
      article h1 {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1.3;
        margin: 0 0 8px;
        letter-spacing: -0.02em;
      }
      article h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 2em 0 0.75em;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--color-border);
      }
      article h3 {
        font-size: 1.25rem;
        font-weight: 600;
        margin: 1.5em 0 0.5em;
      }
      article h4 {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 1.2em 0 0.4em;
      }
      article p {
        margin: 1em 0;
      }
      article img {
        border-radius: var(--radius);
        margin: 1.5em 0;
      }
      article pre {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 16px 20px;
        overflow-x: auto;
        font-family: var(--font-mono);
        font-size: 0.88em;
        line-height: 1.6;
        margin: 1.5em 0;
      }
      article code {
        font-family: var(--font-mono);
        font-size: 0.88em;
        background: var(--color-surface);
        padding: 2px 6px;
        border-radius: 4px;
      }
      article pre code {
        background: none;
        padding: 0;
        font-size: 1em;
      }
      article blockquote {
        border-left: 4px solid var(--color-primary);
        margin: 1.5em 0;
        padding: 12px 20px;
        background: var(--color-surface);
        border-radius: 0 var(--radius) var(--radius) 0;
        color: var(--color-text-secondary);
      }
      article blockquote p:first-child { margin-top: 0; }
      article blockquote p:last-child { margin-bottom: 0; }
      article ul, article ol {
        padding-left: 1.5em;
        margin: 0.75em 0;
      }
      article li {
        margin: 0.35em 0;
      }
      article hr {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2em 0;
      }
      article table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5em 0;
        font-size: 0.95em;
      }
      article th, article td {
        padding: 10px 14px;
        border: 1px solid var(--color-border);
        text-align: left;
      }
      article th {
        background: var(--color-surface);
        font-weight: 600;
      }

      /* === Post Card === */
      .post-card {
        display: block;
        padding: 20px 24px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        margin-bottom: 16px;
        transition: box-shadow var(--transition), border-color var(--transition), transform var(--transition);
        text-decoration: none !important;
      }
      .post-card:hover {
        box-shadow: var(--shadow-md);
        border-color: var(--color-primary);
        transform: translateY(-1px);
      }
      .post-card-title {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--color-text);
        margin: 0 0 8px;
        line-height: 1.4;
      }
      .post-card-desc {
        font-size: 0.9rem;
        color: var(--color-text-secondary);
        margin: 0;
        line-height: 1.6;
      }
      .post-card-meta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        font-size: 0.8rem;
        color: var(--color-text-secondary);
        margin-top: 10px;
      }

      /* === Article Meta === */
      .article-meta {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
        font-size: 0.88rem;
        color: var(--color-text-secondary);
        margin: 8px 0 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--color-border);
      }
      .article-meta .divider { color: var(--color-border); }
      .tag {
        display: inline-block;
        padding: 2px 10px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 99px;
        font-size: 0.78rem;
        color: var(--color-text-secondary);
        transition: background var(--transition);
      }
      .tag:hover {
        background: var(--color-surface-hover);
        text-decoration: none;
      }

      /* === Breadcrumb === */
      .breadcrumb {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        font-size: 0.85rem;
        color: var(--color-text-secondary);
        margin-bottom: 20px;
      }
      .breadcrumb a { color: var(--color-primary); }
      .breadcrumb .sep { color: var(--color-border); }

      /* === TOC (Table of Contents) === */
      .toc {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        margin: 24px 0;
      }
      .toc-title {
        font-size: 0.95rem;
        font-weight: 700;
        margin: 0 0 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .toc-list li { margin: 5px 0; }
      .toc-list a {
        font-size: 0.88rem;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: color var(--transition);
      }
      .toc-list a:hover { color: var(--color-primary); }
      .toc-list .depth-3 { padding-left: 1.2em; }
      .toc-list .depth-4 { padding-left: 2.4em; }

      /* === Related Posts === */
      .related-section {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid var(--color-border);
      }
      .related-section h2 {
        font-size: 1.3rem;
        margin: 0 0 16px;
        border: none;
        padding: 0;
      }

      /* === Giscus === */
      .giscus-container {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid var(--color-border);
      }

      /* === Section Pages (about, contact, privacy, terms) === */
      .section-page h1 {
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 8px;
      }
      .section-page h2 {
        font-size: 1.35rem;
        margin-top: 2em;
      }
      .section-page h3 {
        font-size: 1.15rem;
        margin-top: 1.5em;
      }
      .section-page section {
        margin-top: 32px;
      }
      .info-box {
        background: var(--color-surface);
        padding: 20px 24px;
        border-radius: var(--radius-lg);
        border: 1px solid var(--color-border);
        margin-top: 16px;
      }
      .info-box h3 { margin-top: 0; }

      /* === Footer === */
      .site-footer {
        margin-top: 64px;
        padding: 32px 0;
        background: var(--color-surface);
        border-top: 1px solid var(--color-border);
      }
      .footer-inner {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 24px;
      }
      .footer-top {
        display: flex;
        justify-content: space-between;
        gap: 32px;
        flex-wrap: wrap;
      }
      .footer-brand {
        max-width: 320px;
      }
      .footer-brand strong {
        font-size: 1.1rem;
      }
      .footer-desc {
        font-size: 0.85rem;
        color: var(--color-text-secondary);
        margin: 8px 0 0;
        line-height: 1.6;
      }
      .footer-links {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        align-items: flex-start;
      }
      .footer-links a {
        font-size: 0.88rem;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: color var(--transition);
      }
      .footer-links a:hover { color: var(--color-primary); }
      .footer-copy {
        font-size: 0.8rem;
        color: var(--color-text-secondary);
        margin-top: 24px;
        padding-top: 16px;
        border-top: 1px solid var(--color-border);
      }

      /* === Pagefind Overrides === */
      .pagefind-ui {
        --pagefind-ui-primary: var(--color-primary);
        --pagefind-ui-text: var(--color-text);
        --pagefind-ui-background: var(--color-bg);
        --pagefind-ui-border: var(--color-border);
        --pagefind-ui-border-width: 1px;
        --pagefind-ui-border-radius: 8px;
        --pagefind-ui-font: var(--font-sans);
      }

      /* === Responsive === */
      @media (max-width: 640px) {
        .main-content { padding: 20px 16px; }
        article h1 { font-size: 1.6rem; }
        article h2 { font-size: 1.25rem; }
        .header-inner { padding: 10px 16px; gap: 12px; }
        .site-nav { gap: 12px; }
        .footer-top { flex-direction: column; }
        .footer-links { gap: 12px; }
        .post-card { padding: 16px; }
      }

      /* === Affiliate Box === */
      .affiliate-notice {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        font-size: 0.8rem;
        color: var(--color-text-secondary);
        margin-bottom: 24px;
      }
      .affiliate-notice a { color: var(--color-primary); }

      .affiliate-box {
        background: var(--color-surface);
        border: 2px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        margin: 28px 0;
      }
      .affiliate-box-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0 0 16px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .affiliate-table {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .affiliate-row {
        display: grid;
        grid-template-columns: 1fr auto auto auto;
        gap: 12px;
        align-items: center;
        padding: 14px 16px;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        transition: box-shadow var(--transition);
      }
      .affiliate-row:hover {
        box-shadow: var(--shadow-md);
      }
      .affiliate-name {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .affiliate-name strong {
        font-size: 1rem;
        font-weight: 700;
      }
      .affiliate-badge {
        display: inline-block;
        padding: 2px 8px;
        background: var(--color-primary);
        color: #fff;
        font-size: 0.7rem;
        font-weight: 600;
        border-radius: 99px;
        width: fit-content;
      }
      .affiliate-features {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        font-size: 0.78rem;
        color: var(--color-text-secondary);
      }
      .affiliate-features span::after {
        content: " · ";
      }
      .affiliate-features span:last-child::after {
        content: "";
      }
      .affiliate-rating {
        font-size: 0.88rem;
        color: #f59e0b;
        font-weight: 600;
        white-space: nowrap;
      }
      .affiliate-price {
        text-align: right;
        white-space: nowrap;
      }
      .affiliate-price .price-amount {
        font-weight: 700;
        font-size: 1rem;
        color: var(--color-text);
        display: block;
      }
      .affiliate-price .price-discount {
        font-size: 0.75rem;
        color: #16a34a;
        font-weight: 600;
      }
      .affiliate-cta a {
        display: inline-block;
        padding: 9px 18px;
        background: var(--color-primary);
        color: #fff !important;
        border-radius: var(--radius);
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none !important;
        transition: background var(--transition);
        white-space: nowrap;
      }
      .affiliate-cta a:hover {
        background: var(--color-primary-hover);
      }
      @media (max-width: 640px) {
        .affiliate-row {
          grid-template-columns: 1fr 1fr;
          grid-template-rows: auto auto;
        }
        .affiliate-name { grid-column: 1 / 3; }
        .affiliate-features { display: none; }
        .affiliate-rating { display: none; }
        .affiliate-price { text-align: left; }
        .affiliate-cta { grid-column: 2; text-align: right; }
      }

      /* === AdSense Slot === */
      .ad-slot {
        margin: 32px 0;
        text-align: center;
      }

      /* === Print === */
      @media print {
        .site-header, .site-footer, .header-search, .giscus-container { display: none; }
        body { background: white; color: black; }
        a { color: inherit; text-decoration: underline; }
      }
    </style>
  </head>
  <body>
    {/* Site Header (只在站点页面渲染) */}
    {siteSlug && siteName ? (
      <header class="site-header">
        <div class="header-inner">
          <a href={`/${siteSlug}/`} class="site-logo">{siteName}</a>
          <nav class="site-nav">
            <a href="/">All Channels</a>
            {otherChannels.map((s) => (
              <a href={`/${s.slug}/`} class="channel-switch">
                {CHANNEL_LABELS[s.slug] ?? s.config.name} →
              </a>
            ))}
            <a href={`/${siteSlug}/posts/`}>Articles</a>
            <a href={`/${siteSlug}/ai-frontiers/`}>AI Frontiers</a>
            <a href={`/${siteSlug}/about/`}>About</a>
            <a href={`/${siteSlug}/contact/`}>Contact</a>
          </nav>
          <div id="search" class="header-search"></div>
        </div>
      </header>
    ) : null}

    <main class="main-content">
      <slot />
    </main>

    {/* Site Footer */}
    {siteSlug && siteName ? (
      <footer class="site-footer">
        <div class="footer-inner">
          <div class="footer-top">
            <div class="footer-brand">
              <strong>{siteName}</strong>
              {siteDescription ? <p class="footer-desc">{siteDescription}</p> : null}
            </div>
            <div class="footer-links">
              <a href="/">All Channels</a>
              {otherChannels.map((s) => (
                <a href={`/${s.slug}/`}>{CHANNEL_LABELS[s.slug] ?? s.config.name}</a>
              ))}
              <a href={`/${siteSlug}/posts/`}>Articles</a>
              <a href={`/${siteSlug}/ai-frontiers/`}>AI Frontiers</a>
              <a href={`/${siteSlug}/about/`}>About</a>
              <a href={`/${siteSlug}/contact/`}>Contact</a>
              <a href={`/${siteSlug}/privacy/`}>Privacy</a>
              <a href={`/${siteSlug}/terms/`}>Terms</a>
              {hasAffiliates ? (
                <a href={`/${siteSlug}/disclosure/`}>Disclosure</a>
              ) : null}
              <a href={`/${siteSlug}/rss.xml`}>RSS</a>
              <a href={`/${siteSlug}/sitemap.xml`}>Sitemap</a>
            </div>
          </div>
          <p class="footer-copy">&copy; {currentYear} {siteName}. All rights reserved.</p>
        </div>
      </footer>
    ) : null}

    {/* Pagefind Search (动态加载，SSG 构建后可用) */}
    <script is:inline>
      (function() {
        var el = document.getElementById('search');
        if (!el) return;
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(link);
        var script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = function() {
          new PagefindUI({
            element: '#search',
            showSubResults: true,
            showImages: false,
            resetStyles: false
          });
        };
        script.onerror = function() {};
        document.head.appendChild(script);
      })();
    </script>

    {/* Web Vitals 监控 */}
    <script is:inline>
      (function() {
        function sendMetric(name, value, id) {
          if (typeof gtag === 'function') {
            gtag('event', name, {
              event_category: 'Web Vitals',
              value: Math.round(name === 'CLS' ? value * 1000 : value),
              event_label: id,
              non_interaction: true
            });
          }
          if (location.hostname === 'localhost' || location.hostname === '127.0.0.1') {
            console.log('[Web Vitals]', name + ':', value.toFixed(2));
          }
        }
        try {
          new PerformanceObserver(function(list) {
            var entries = list.getEntries();
            var last = entries[entries.length - 1];
            if (last) sendMetric('LCP', last.startTime, 'v1');
          }).observe({ type: 'largest-contentful-paint', buffered: true });

          var inpValue = 0;
          new PerformanceObserver(function(list) {
            list.getEntries().forEach(function(entry) {
              if (entry.duration > inpValue) inpValue = entry.duration;
            });
            sendMetric('INP', inpValue, 'v1');
          }).observe({ type: 'event', buffered: true, durationThreshold: 40 });

          var clsValue = 0;
          new PerformanceObserver(function(list) {
            list.getEntries().forEach(function(entry) {
              if (!entry.hadRecentInput) clsValue += entry.value;
            });
            sendMetric('CLS', clsValue, 'v1');
          }).observe({ type: 'layout-shift', buffered: true });

          new PerformanceObserver(function(list) {
            list.getEntries().forEach(function(entry) {
              if (entry.name === 'first-contentful-paint') {
                sendMetric('FCP', entry.startTime, 'v1');
              }
            });
          }).observe({ type: 'paint', buffered: true });

          if (performance.getEntriesByType) {
            var nav = performance.getEntriesByType('navigation')[0];
            if (nav) sendMetric('TTFB', nav.responseStart, 'v1');
          }
        } catch(e) {}
      })();
    </script>
  </body>
</html>
