---
import { CHANNEL_LABELS, postsHubLabel, postsNavLabel, isPathActive } from "../lib/channel-nav";
import { getPublicRootBaseUrl } from "../lib/root-base-url";
import { DEFAULT_HTML_ROBOTS } from "../lib/seo-defaults";
import { getAllSites, toCanonical } from "../lib/site-data";

const rootSeo = getPublicRootBaseUrl();
const sitemapIndexHref = import.meta.env.DEV
  ? "/sitemap_index.xml"
  : toCanonical(rootSeo, "/sitemap_index.xml");
const sitemapUrlsetHref = import.meta.env.DEV
  ? "/sitemap.xml"
  : toCanonical(rootSeo, "/sitemap.xml");
const htmlSitemapHref = import.meta.env.DEV ? "/sitemap/" : toCanonical(rootSeo, "/sitemap/");
const robotsTxtHref = import.meta.env.DEV ? "/robots.txt" : toCanonical(rootSeo, "/robots.txt");

type Props = {
  title: string;
  description?: string;
  canonical: string;
  keywords?: string[];
  openGraph?: {
    type?: "website" | "article";
    title?: string;
    description?: string;
    url?: string;
    siteName?: string;
    image?: string;
    locale?: string;
    publishedTime?: string;
    modifiedTime?: string;
    tags?: string[];
  };
  twitter?: {
    card?: "summary" | "summary_large_image";
    title?: string;
    description?: string;
    image?: string;
    site?: string;
    creator?: string;
  };
  jsonLd?: unknown | unknown[];
  siteSlug?: string;
  siteName?: string;
  siteDescription?: string;
  lang?: string;
  analytics?: {
    ga4Id?: string;
    cfBeacon?: string;
  };
  adsense?: {
    publisherId?: string;
    adSlot?: string;
  };
  hasAffiliates?: boolean;
  /** 榛樿 index,follow锛涜崏绋块〉鍙紶 noindex,nofollow */
  robots?: string;
  /** Plain-text alternate URL (e.g. ai-corpus /posts/.../plain.txt) */
  alternatePlain?: string;
  /** 鏍圭珯椤舵爮鍝佺墝鏂囨锛堝棣栭〉鏍囪锛夛紱榛樿 wordok.top */
  rootHeaderLabel?: string;
};

const {
  title,
  description,
  canonical,
  keywords,
  openGraph,
  twitter,
  jsonLd,
  siteSlug,
  siteName,
  siteDescription,
  lang,
  analytics,
  adsense,
  hasAffiliates,
  robots,
  alternatePlain,
  rootHeaderLabel,
} = Astro.props;

const rootHeaderTitle = rootHeaderLabel ?? "wordok.top";

const robotsContent = robots ?? DEFAULT_HTML_ROBOTS;
const hrefLang = lang || "en";

function toJsonLdArray(v: unknown | unknown[] | undefined): unknown[] {
  if (!v) return [];
  return Array.isArray(v) ? v : [v];
}

function safeJsonStringify(v: unknown): string {
  return JSON.stringify(v).replace(/<\/script/gi, "<\\/script");
}

const currentYear = new Date().getFullYear();

const allSites = getAllSites();
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang={lang || "en"}>
  <head>
    {/* Ezoic Privacy Scripts - 蹇呴』鍦ㄦ渶椤堕儴鍔犺浇 */}
    <script is:inline data-cfasync="false" src="https://cmp.gatekeeperconsent.com/min.js"></script>
    <script is:inline data-cfasync="false" src="https://the.gatekeeperconsent.com/cmp.min.js"></script>
    
    {/* Ezoic Header Script */}
    <script is:inline async src="//www.ezojs.com/ezoic/sa.min.js"></script>
    <script is:inline>
      window.ezstandalone = window.ezstandalone || {};
      ezstandalone.cmd = ezstandalone.cmd || [];
    </script>
    <script is:inline async src="//ezoicanalytics.com/analytics.js"></script>
    
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fafafa" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0c0a12" />
    <meta name="generator" content={Astro.generator} />
    <!-- 榛樿鍏佽鏀跺綍锛涗粎鑽夌鎴?frontmatter.robots 瑕嗙洊鏃朵负 noindex -->
    <meta name="robots" content={robotsContent} />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {keywords?.length ? (
      <meta name="keywords" content={keywords.join(",")} />
    ) : null}
    <link rel="canonical" href={canonical} />
    {alternatePlain ? <link rel="alternate" type="text/plain" href={alternatePlain} title="Plain text" /> : null}
    <link rel="alternate" hreflang={hrefLang} href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="sitemap" type="application/xml" title="Sitemap index" href={sitemapIndexHref} />
    <link rel="sitemap" type="application/xml" title="Full sitemap" href={sitemapUrlsetHref} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/og-default.png" />

    {/* RSS Autodiscovery */}
    {siteSlug ? (
      <link
        rel="alternate"
        type="application/rss+xml"
        title={siteName ? `${siteName} RSS Feed` : "RSS Feed"}
        href={`/${siteSlug}/rss.xml`}
      />
    ) : null}

    {/* Preconnect for performance */}
    {analytics?.ga4Id ? (
      <link rel="preconnect" href="https://www.googletagmanager.com" />
    ) : null}
    {adsense?.publisherId ? (
      <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
    ) : null}

    {/* Google AdSense */}
    {adsense?.publisherId ? (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsense.publisherId}`}
        crossorigin="anonymous"
      ></script>
    ) : null}

    {/* OpenGraph */}
    {openGraph?.title ? <meta property="og:title" content={openGraph.title} /> : null}
    {openGraph?.description ? (
      <meta property="og:description" content={openGraph.description} />
    ) : null}
    <meta property="og:url" content={openGraph?.url ?? canonical} />
    <meta property="og:type" content={openGraph?.type ?? "website"} />
    {openGraph?.siteName ? <meta property="og:site_name" content={openGraph.siteName} /> : null}
    {openGraph?.locale ? <meta property="og:locale" content={openGraph.locale} /> : null}
    {openGraph?.image ? (
      <>
        <meta property="og:image" content={openGraph.image} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    ) : null}
    {openGraph?.publishedTime ? (
      <meta property="article:published_time" content={openGraph.publishedTime} />
    ) : null}
    {openGraph?.modifiedTime ? (
      <meta property="article:modified_time" content={openGraph.modifiedTime} />
    ) : null}
    {openGraph?.tags?.length
      ? openGraph.tags.map((t) => <meta property="article:tag" content={t} />)
      : null}

    {/* Twitter Card */}
    {twitter ? <meta name="twitter:card" content={twitter.card ?? "summary"} /> : null}
    {twitter?.title ? <meta name="twitter:title" content={twitter.title} /> : null}
    {twitter?.description ? (
      <meta name="twitter:description" content={twitter.description} />
    ) : null}
    {twitter?.image ? <meta name="twitter:image" content={twitter.image} /> : null}
    {twitter?.site ? <meta name="twitter:site" content={twitter.site} /> : null}
    {twitter?.creator ? <meta name="twitter:creator" content={twitter.creator} /> : null}

    {/* JSON-LD */}
    {toJsonLdArray(jsonLd).map((obj) => (
      <script type="application/ld+json" set:html={safeJsonStringify(obj)} />
    ))}

    {/* Organization Schema (site-wide) */}
    <script type="application/ld+json" set:html={safeJsonStringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "wordok.top",
      "url": "https://wordok.top",
      "logo": "https://wordok.top/og-default.png",
      "sameAs": [],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "iwangzhanpeng94@gmail.com",
        "contactType": "customer service"
      }
    })} />

    {/* Google Analytics 4 */}
    {analytics?.ga4Id ? (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${analytics.ga4Id}`}></script>
    ) : null}
    {analytics?.ga4Id ? (
      <script define:vars={{ gaId: analytics.ga4Id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(...args: any[]) { window.dataLayer.push(args); }
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    ) : null}

    {/* Cloudflare Web Analytics */}
    {analytics?.cfBeacon ? (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${analytics.cfBeacon}"}`}
      ></script>
    ) : null}

    <style is:global>
      /* === Design System (purple 鈫?cyan, light/dark) === */
      :root {
        --color-bg: #fafafa;
        --color-surface: #f4f4f5;
        --color-surface-hover: #e4e4e7;
        --color-border: #e4e4e7;
        --color-text: #18181b;
        --color-text-secondary: #52525b;
        --color-primary: #7c3aed;
        --color-primary-hover: #6d28d9;
        --color-accent: #06b6d4;
        --color-accent-hover: #0891b2;
        --gradient-title: linear-gradient(120deg, #7c3aed 0%, #8b5cf6 45%, #06b6d4 100%);
        --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        --font-mono: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
        --container-max: 860px;
        --radius: 8px;
        --radius-lg: 12px;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
        --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
        --transition: 0.2s ease;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --color-bg: #0c0a12;
          --color-surface: #16121f;
          --color-surface-hover: #1f1a2e;
          --color-border: #2e2654;
          --color-text: #f4f4f5;
          --color-text-secondary: #a1a1aa;
          --color-primary: #a78bfa;
          --color-primary-hover: #c4b5fd;
          --color-accent: #22d3ee;
          --color-accent-hover: #67e8f9;
          --gradient-title: linear-gradient(120deg, #a78bfa 0%, #c084fc 45%, #22d3ee 100%);
        }
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; }
      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }

      body {
        font-family: var(--font-sans);
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        padding-left: env(safe-area-inset-left, 0px);
        padding-right: env(safe-area-inset-right, 0px);
      }

      a {
        color: var(--color-primary);
        text-decoration: none;
        transition: color var(--transition);
      }
      a:hover {
        color: var(--color-primary-hover);
        text-decoration: underline;
      }

      img { max-width: 100%; height: auto; }

      /* === Site Header === */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        overflow: visible;
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
        padding: 0;
        padding-top: env(safe-area-inset-top, 0px);
      }
      @media (prefers-color-scheme: dark) {
        .site-header {
          background: rgba(12, 10, 18, 0.88);
        }
      }
      .header-inner {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 10px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        overflow: visible;
      }
      .header-inner-toolbar {
        justify-content: space-between;
        align-items: center;
      }
      .header-inner-stack {
        flex-direction: column;
        align-items: stretch;
        gap: 8px;
        padding-bottom: 10px;
      }
      .header-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px 20px;
        flex-wrap: wrap;
        width: 100%;
        overflow: visible;
      }
      .header-toolbar-left {
        display: flex;
        align-items: center;
        gap: 10px 14px;
        flex-wrap: wrap;
        min-width: 0;
      }
      .header-crumb {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 4px 6px;
        font-size: 0.875rem;
        line-height: 1.3;
      }
      .header-crumb a {
        text-decoration: none !important;
      }
      .header-crumb-root {
        color: var(--color-text-secondary) !important;
        font-weight: 500;
      }
      .header-crumb-root:hover {
        color: var(--color-primary) !important;
      }
      .header-crumb-sep {
        color: var(--color-border);
        user-select: none;
        font-weight: 500;
      }
      .header-crumb-site {
        color: var(--color-text) !important;
        font-weight: 700;
      }
      .header-crumb-site:hover {
        color: var(--color-primary) !important;
      }
      .header-channels-dropdown {
        position: relative;
      }
      .header-channels-summary {
        list-style: none;
        cursor: pointer;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--color-text-secondary);
        padding: 6px 12px;
        border-radius: var(--radius);
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        transition: color var(--transition), border-color var(--transition), background var(--transition);
      }
      .header-channels-summary::-webkit-details-marker {
        display: none;
      }
      .header-channels-dropdown[open] .header-channels-summary {
        color: var(--color-primary);
        border-color: var(--color-primary);
      }
      .header-channels-summary:hover {
        color: var(--color-primary);
        border-color: var(--color-primary);
      }
      .header-channels-panel {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        min-width: min(100vw - 48px, 240px);
        max-height: min(70vh, 360px);
        overflow-y: auto;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        padding: 6px;
        z-index: 200;
      }
      .header-channels-link {
        display: block;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-text-secondary) !important;
        text-decoration: none !important;
        transition: background var(--transition), color var(--transition);
      }
      .header-channels-link:hover {
        background: var(--color-surface-hover);
        color: var(--color-primary) !important;
      }
      .header-channels-link--here,
      .header-channels-link[aria-current="page"] {
        background: color-mix(in srgb, var(--color-primary) 12%, transparent);
        color: var(--color-primary) !important;
        font-weight: 600;
      }
      .site-logo-root {
        font-size: clamp(0.8rem, 2.8vw, 1.05rem);
        font-weight: 700;
        text-decoration: none !important;
        line-height: 1.25;
        max-width: min(100%, 16rem);
        white-space: normal;
        text-wrap: balance;
        text-align: left;
        background: var(--gradient-title);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .site-logo-root:hover {
        opacity: 0.88;
      }
      .site-logo {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--color-text) !important;
        text-decoration: none !important;
        white-space: nowrap;
      }
      .site-nav {
        display: flex;
        gap: 4px 16px;
        flex-wrap: wrap;
        align-items: center;
        width: 100%;
        padding-top: 6px;
        border-top: 1px solid var(--color-border);
      }
      .site-nav-primary {
        row-gap: 4px;
      }
      .site-nav a {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-text-secondary);
        text-decoration: none;
        padding: 6px 2px;
        border-bottom: 2px solid transparent;
        transition: color var(--transition), border-color var(--transition);
      }
      .site-nav a:hover {
        color: var(--color-primary);
        border-bottom-color: var(--color-primary);
        text-decoration: none;
      }
      .site-nav a[aria-current="page"] {
        color: var(--color-primary);
        border-bottom-color: var(--color-primary);
        font-weight: 600;
      }
      .header-toolbar .header-search {
        margin-left: auto;
        flex-shrink: 0;
      }
      .header-inner-toolbar .header-search {
        margin-left: auto;
      }
      .header-search {
        --pf-input-bg: #ffffff;
        --pf-input-fg: #18181b;
        --pf-input-border: #d4d4d8;
        --pf-input-placeholder: #71717a;
        --pf-input-icon: #52525b;
        position: relative;
        z-index: 400;
        flex: 1 1 180px;
        min-width: 0;
        max-width: min(420px, 100%);
      }
      @media (prefers-color-scheme: dark) {
        .header-search {
          --pf-input-bg: #f8fafc;
          --pf-input-fg: #0f172a;
          --pf-input-border: #94a3b8;
          --pf-input-placeholder: #64748b;
          --pf-input-icon: #475569;
        }
      }
      .header-search .pagefind-ui {
        --pagefind-ui-scale: 0.62;
        width: 100% !important;
        max-width: 100%;
        position: relative;
      }
      .header-search .pagefind-ui__search-input {
        width: 100% !important;
        max-width: none !important;
        min-width: 0 !important;
        height: auto !important;
        min-height: 44px;
        padding: 0.5rem 3.25rem 0.5rem 2.15rem !important;
        font-size: 0.875rem !important;
        font-weight: 600 !important;
        box-sizing: border-box !important;
        background-color: var(--pf-input-bg) !important;
        color: var(--pf-input-fg) !important;
        caret-color: var(--pf-input-fg) !important;
        border-color: var(--pf-input-border) !important;
        -webkit-text-fill-color: var(--pf-input-fg) !important;
      }
      .header-search .pagefind-ui__search-input::placeholder {
        color: var(--pf-input-placeholder) !important;
        opacity: 1 !important;
        -webkit-text-fill-color: var(--pf-input-placeholder) !important;
      }
      .header-search .pagefind-ui__search-input:-webkit-autofill,
      .header-search .pagefind-ui__search-input:-webkit-autofill:hover,
      .header-search .pagefind-ui__search-input:-webkit-autofill:focus {
        -webkit-box-shadow: 0 0 0 1000px var(--pf-input-bg) inset !important;
        -webkit-text-fill-color: var(--pf-input-fg) !important;
        caret-color: var(--pf-input-fg) !important;
      }
      .header-search .pagefind-ui__form::before {
        top: 50% !important;
        left: 0.65rem !important;
        transform: translateY(-50%) !important;
        width: 15px !important;
        height: 15px !important;
        background-color: var(--pf-input-icon) !important;
        opacity: 0.9 !important;
      }
      .header-search .pagefind-ui__search-clear {
        top: 50% !important;
        right: 4px !important;
        transform: translateY(-50%);
        height: auto !important;
        min-height: 36px;
        font-size: 0.75rem !important;
        padding: 0 10px !important;
        box-sizing: border-box !important;
        color: var(--pf-input-fg) !important;
        background-color: var(--pf-input-bg) !important;
        -webkit-text-fill-color: var(--pf-input-fg) !important;
      }
      .header-search .pagefind-ui__drawer {
        position: absolute !important;
        left: 0 !important;
        right: 0 !important;
        top: calc(100% + 8px) !important;
        width: 100% !important;
        max-width: min(100vw - 24px, 520px) !important;
        flex-direction: column !important;
        flex-wrap: nowrap !important;
        gap: 0.5rem !important;
        padding: 10px !important;
        background: var(--color-bg) !important;
        border: 1px solid var(--color-border) !important;
        border-radius: var(--radius-lg) !important;
        box-shadow: var(--shadow-md) !important;
        max-height: min(75vh, 560px) !important;
        overflow-x: hidden !important;
        overflow-y: auto !important;
        box-sizing: border-box !important;
      }
      .header-search .pagefind-ui__results-area {
        min-width: 0 !important;
        width: 100% !important;
        flex: none !important;
        margin-top: 0 !important;
        max-width: 100% !important;
      }
      .header-search .pagefind-ui__filter-panel {
        min-width: 0 !important;
        width: 100% !important;
        max-width: 100% !important;
        margin-top: 0 !important;
      }
      .header-search .pagefind-ui__result {
        flex-wrap: wrap !important;
        align-items: flex-start !important;
        padding: 10px 0 !important;
        gap: 8px !important;
      }
      .header-search .pagefind-ui__result-inner {
        min-width: 0 !important;
        max-width: 100% !important;
      }
      .header-search .pagefind-ui__result-excerpt {
        min-width: 0 !important;
        max-width: 100% !important;
        font-size: 0.8125rem !important;
        word-break: break-word !important;
        overflow-wrap: anywhere !important;
      }
      .header-search .pagefind-ui__result-title {
        font-size: 0.9rem !important;
      }
      .header-search .pagefind-ui__message {
        margin-top: 0 !important;
        padding: 8px 0 !important;
        height: auto !important;
        min-height: 0 !important;
      }

      /* === Container === */
      .container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 24px;
        width: 100%;
      }

      /* === Main Content === */
      .main-content {
        flex: 1;
        padding: 32px 24px;
        max-width: var(--container-max);
        margin: 0 auto;
        width: 100%;
      }

      /* === Article Typography === */
      article h1 {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1.3;
        margin: 0 0 8px;
        letter-spacing: -0.02em;
        background: var(--gradient-title);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      article h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 2em 0 0.75em;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--color-border);
      }
      article h3 {
        font-size: 1.25rem;
        font-weight: 600;
        margin: 1.5em 0 0.5em;
      }
      article h4 {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 1.2em 0 0.4em;
      }
      article p {
        margin: 1em 0;
      }
      article img {
        border-radius: var(--radius);
        margin: 1.5em 0;
      }
      article pre {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 16px 20px;
        overflow-x: auto;
        font-family: var(--font-mono);
        font-size: 0.88em;
        line-height: 1.6;
        margin: 1.5em 0;
      }
      article code {
        font-family: var(--font-mono);
        font-size: 0.88em;
        background: var(--color-surface);
        padding: 2px 6px;
        border-radius: 4px;
      }
      article pre code {
        background: none;
        padding: 0;
        font-size: 1em;
      }
      article blockquote {
        border-left: 4px solid var(--color-primary);
        margin: 1.5em 0;
        padding: 12px 20px;
        background: var(--color-surface);
        border-radius: 0 var(--radius) var(--radius) 0;
        color: var(--color-text-secondary);
      }
      article blockquote p:first-child { margin-top: 0; }
      article blockquote p:last-child { margin-bottom: 0; }
      article ul, article ol {
        padding-left: 1.5em;
        margin: 0.75em 0;
      }
      article li {
        margin: 0.35em 0;
      }
      article hr {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2em 0;
      }
      article table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5em 0;
        font-size: 0.95em;
      }
      article th, article td {
        padding: 10px 14px;
        border: 1px solid var(--color-border);
        text-align: left;
      }
      article th {
        background: var(--color-surface);
        font-weight: 600;
      }
      @media (max-width: 640px) {
        article {
          overflow-wrap: anywhere;
          word-break: break-word;
        }
        article table {
          display: block;
          width: 100%;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          font-size: 0.82rem;
        }
        article th, article td {
          padding: 8px 10px;
        }
      }

      /* === Post Card === */
      .post-card {
        display: block;
        padding: 20px 24px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        margin-bottom: 16px;
        transition: box-shadow var(--transition), border-color var(--transition), transform var(--transition);
        text-decoration: none !important;
      }
      .post-card:hover {
        box-shadow: var(--shadow-md);
        border-color: var(--color-primary);
        transform: translateY(-1px);
      }
      .post-card-title {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--color-text);
        margin: 0 0 8px;
        line-height: 1.4;
      }
      .post-card-desc {
        font-size: 0.9rem;
        color: var(--color-text-secondary);
        margin: 0;
        line-height: 1.6;
      }
      .post-card-meta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        font-size: 0.8rem;
        color: var(--color-text-secondary);
        margin-top: 10px;
      }

      /* === Article Meta === */
      .article-meta {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
        font-size: 0.88rem;
        color: var(--color-text-secondary);
        margin: 8px 0 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--color-border);
      }
      .article-meta .divider { color: var(--color-border); }

      .machine-snapshot {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 18px 20px;
        margin: 0 0 24px;
      }
      .machine-snapshot-heading {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 8px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--color-text-secondary);
      }
      .machine-snapshot p {
        margin: 0 0 12px;
        line-height: 1.55;
      }
      .machine-snapshot ul {
        margin: 0;
        padding-left: 1.25rem;
      }
      .machine-snapshot li {
        margin: 6px 0;
      }

      .tag {
        display: inline-block;
        padding: 2px 10px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 99px;
        font-size: 0.78rem;
        color: var(--color-text-secondary);
        transition: background var(--transition);
      }
      .tag:hover {
        background: var(--color-surface-hover);
        text-decoration: none;
      }

      /* === Breadcrumb === */
      .breadcrumb {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        font-size: 0.85rem;
        color: var(--color-text-secondary);
        margin-bottom: 20px;
      }
      .breadcrumb a { color: var(--color-primary); }
      .breadcrumb .sep { color: var(--color-border); }

      /* === TOC (Table of Contents) === */
      .toc {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        margin: 24px 0;
      }
      .toc-title {
        font-size: 0.95rem;
        font-weight: 700;
        margin: 0 0 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .toc-list li { margin: 5px 0; }
      .toc-list a {
        font-size: 0.88rem;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: color var(--transition);
      }
      .toc-list a:hover { color: var(--color-primary); }
      .toc-list .depth-3 { padding-left: 1.2em; }
      .toc-list .depth-4 { padding-left: 2.4em; }

      /* === Related Posts === */
      .related-section {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid var(--color-border);
      }
      .related-section h2 {
        font-size: 1.3rem;
        margin: 0 0 16px;
        border: none;
        padding: 0;
      }

      /* === Giscus === */
      .giscus-container {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid var(--color-border);
      }

      /* === Section Pages (about, contact, privacy, terms) === */
      .section-page h1 {
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 8px;
      }
      .section-page h2 {
        font-size: 1.35rem;
        margin-top: 2em;
      }
      .section-page h3 {
        font-size: 1.15rem;
        margin-top: 1.5em;
      }
      .section-page section {
        margin-top: 32px;
      }
      .info-box {
        background: var(--color-surface);
        padding: 20px 24px;
        border-radius: var(--radius-lg);
        border: 1px solid var(--color-border);
        margin-top: 16px;
      }
      .info-box h3 { margin-top: 0; }

      /* === Footer === */
      .site-footer {
        margin-top: 64px;
        padding: 32px 0;
        background: var(--color-surface);
        border-top: 1px solid var(--color-border);
      }
      .footer-inner {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 24px;
      }
      .footer-top {
        display: flex;
        justify-content: space-between;
        gap: 32px;
        flex-wrap: wrap;
      }
      .footer-brand {
        max-width: 320px;
      }
      .footer-brand strong {
        font-size: 1.1rem;
      }
      .footer-desc {
        font-size: 0.85rem;
        color: var(--color-text-secondary);
        margin: 8px 0 0;
        line-height: 1.6;
      }
      .footer-links {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        align-items: flex-start;
      }
      .footer-links a {
        font-size: 0.88rem;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: color var(--transition);
      }
      .footer-links a:hover { color: var(--color-primary); }
      .footer-channel-hubs {
        margin-top: 20px;
        padding-top: 18px;
        border-top: 1px solid var(--color-border);
      }
      .footer-hub-title {
        font-size: 0.75rem;
        font-weight: 600;
        margin: 0 0 10px;
        color: var(--color-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .footer-hub-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 18px;
      }
      .footer-hub-group {
        font-size: 0.78rem;
        line-height: 1.5;
        color: var(--color-text-secondary);
      }
      .footer-hub-group a {
        color: var(--color-primary);
        text-decoration: none;
      }
      .footer-hub-group a:hover {
        text-decoration: underline;
      }
      .footer-hub-sep {
        color: var(--color-border);
      }
      .footer-copy {
        font-size: 0.8rem;
        color: var(--color-text-secondary);
        margin-top: 18px;
        padding-top: 14px;
        border-top: 1px solid var(--color-border);
      }

      /* === Pagefind Overrides === */
      .pagefind-ui {
        --pagefind-ui-primary: var(--color-primary);
        --pagefind-ui-text: var(--color-text);
        --pagefind-ui-background: var(--color-bg);
        --pagefind-ui-border: var(--color-border);
        --pagefind-ui-border-width: 1px;
        --pagefind-ui-border-radius: 8px;
        --pagefind-ui-font: var(--font-sans);
      }

      @media (max-width: 720px) {
        .header-inner-toolbar {
          flex-direction: column;
          align-items: stretch;
          gap: 10px;
        }
        .header-toolbar {
          flex-direction: column;
          align-items: stretch;
          gap: 10px;
        }
        .header-toolbar .header-search {
          margin-left: 0;
          width: 100%;
        }
        .header-search {
          width: 100%;
        }
        .header-search .pagefind-ui__search-input {
          max-width: none;
          width: 100%;
        }
        .header-channels-panel {
          left: 0;
          right: 0;
          width: 100%;
          max-width: none;
        }
        .site-nav {
          width: 100%;
          flex-wrap: nowrap;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          gap: 14px;
          padding-bottom: 6px;
          scrollbar-width: thin;
        }
        .site-nav a {
          flex-shrink: 0;
          min-height: 44px;
          display: inline-flex;
          align-items: center;
          touch-action: manipulation;
        }
      }

      /* === Responsive === */
      @media (max-width: 640px) {
        .main-content { padding: 20px 16px; }
        article h1 { font-size: 1.6rem; }
        article h2 { font-size: 1.25rem; }
        .header-inner { padding: 10px 16px; gap: 12px; }
        .site-nav { gap: 12px; }
        .footer-top { flex-direction: column; }
        .footer-links { gap: 12px; }
        .post-card { padding: 16px; }
        .site-footer {
          padding-bottom: max(32px, env(safe-area-inset-bottom, 0px));
        }
      }

      /* === Affiliate Box === */
      .affiliate-notice {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        font-size: 0.8rem;
        color: var(--color-text-secondary);
        margin-bottom: 24px;
      }
      .affiliate-notice a { color: var(--color-primary); }

      .ymyl-disclaimer {
        font-size: 0.8rem;
        color: var(--color-text-secondary);
        padding: 10px 16px;
        background: var(--color-surface);
        border-left: 4px solid var(--color-primary);
        border-radius: 0 var(--radius) var(--radius) 0;
        margin-bottom: 24px;
      }

      .affiliate-box {
        background: var(--color-surface);
        border: 2px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        margin: 28px 0;
      }
      .affiliate-box-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0 0 16px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .affiliate-table {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .affiliate-row {
        display: grid;
        grid-template-columns: 1fr auto auto auto;
        gap: 12px;
        align-items: center;
        padding: 14px 16px;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        transition: box-shadow var(--transition);
      }
      .affiliate-row:hover {
        box-shadow: var(--shadow-md);
      }
      .affiliate-name {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .affiliate-name strong {
        font-size: 1rem;
        font-weight: 700;
      }
      .affiliate-badge {
        display: inline-block;
        padding: 2px 8px;
        background: var(--color-primary);
        color: #fff;
        font-size: 0.7rem;
        font-weight: 600;
        border-radius: 99px;
        width: fit-content;
      }
      .affiliate-features {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        font-size: 0.78rem;
        color: var(--color-text-secondary);
      }
      .affiliate-features span::after {
        content: " 路 ";
      }
      .affiliate-features span:last-child::after {
        content: "";
      }
      .affiliate-rating {
        font-size: 0.88rem;
        color: #f59e0b;
        font-weight: 600;
        white-space: nowrap;
      }
      .affiliate-price {
        text-align: right;
        white-space: nowrap;
      }
      .affiliate-price .price-amount {
        font-weight: 700;
        font-size: 1rem;
        color: var(--color-text);
        display: block;
      }
      .affiliate-price .price-discount {
        font-size: 0.75rem;
        color: #16a34a;
        font-weight: 600;
      }
      .affiliate-cta a {
        display: inline-block;
        padding: 9px 18px;
        background: var(--color-primary);
        color: #fff !important;
        border-radius: var(--radius);
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none !important;
        transition: background var(--transition);
        white-space: nowrap;
      }
      .affiliate-cta a:hover {
        background: var(--color-primary-hover);
      }
      @media (max-width: 640px) {
        .affiliate-row {
          grid-template-columns: 1fr 1fr;
          grid-template-rows: auto auto;
        }
        .affiliate-name { grid-column: 1 / 3; }
        .affiliate-features { display: none; }
        .affiliate-rating { display: none; }
        .affiliate-price { text-align: left; }
        .affiliate-cta { grid-column: 2; text-align: right; }
      }

      /* === AdSense Slot === */
      .ad-slot {
        margin: 32px 0;
        text-align: center;
      }

      /* === Print === */
      .root-discovery-footer {
        margin-top: auto;
        padding: 16px 24px max(24px, env(safe-area-inset-bottom));
        max-width: var(--container-max);
        margin-left: auto;
        margin-right: auto;
        width: 100%;
        border-top: 1px solid var(--color-border);
      }
      .root-discovery-footer p {
        margin: 0;
        font-size: 0.78rem;
        color: var(--color-text-secondary);
        text-align: center;
        line-height: 1.55;
      }
      .root-discovery-footer a {
        color: var(--color-primary);
        text-decoration: none;
      }
      .root-discovery-footer a:hover {
        text-decoration: underline;
      }

      @media print {
        .site-header, .site-footer, .header-search, .giscus-container, .root-discovery-footer {
          display: none;
        }
        body { background: white; color: black; }
        a { color: inherit; text-decoration: underline; }
      }
    </style>
  </head>
  <body>
    {!siteSlug ? (
      <header class="site-header">
        <div class="header-inner header-inner-toolbar">
          <a href="/" class="site-logo-root">{rootHeaderTitle}</a>
          <div id="search" class="header-search"></div>
        </div>
      </header>
    <!-- Ezoic Header Ad -->
    <div class="ad-slot ezoic-ad ezoic-ad-1" data-ezoic-ad-unit-id="header-ad">
      <!-- Header advertisement will be loaded here -->
    </div>

    ) : null}

    {siteSlug && siteName ? (
      <header class="site-header">
        <div class="header-inner header-inner-stack">
          <div class="header-toolbar">
            <div class="header-toolbar-left">
              <nav class="header-crumb" aria-label="Site network">
                <a href="/" class="header-crumb-root">wordok.top</a>
                <span class="header-crumb-sep" aria-hidden="true">/</span>
                <a href={`/${siteSlug}/`} class="header-crumb-site">{siteName}</a>
              </nav>
              <details class="header-channels-dropdown">
                <summary class="header-channels-summary">All channels</summary>
                <div class="header-channels-panel">
                  {allSites.map((s) => (
                    <a
                      href={`/${s.slug}/`}
                      class:list={["header-channels-link", { "header-channels-link--here": siteSlug === s.slug }]}
                      aria-current={siteSlug === s.slug ? "page" : undefined}
                    >
                      {CHANNEL_LABELS[s.slug] ?? s.config.name}
                    </a>
                  ))}
                </div>
              </details>
            </div>
            <div id="search" class="header-search"></div>
          </div>
          <nav class="site-nav site-nav-primary" aria-label="This site">
            <a
              href={`/${siteSlug}/`}
              aria-current={isPathActive(pathname, `/${siteSlug}/`, "exact") ? "page" : undefined}
            >
              Home
            </a>
            <a
              href={`/${siteSlug}/posts/`}
              aria-current={isPathActive(pathname, `/${siteSlug}/posts/`, "prefix") ? "page" : undefined}
            >
              {postsNavLabel(siteSlug)}
            </a>
            <a
              href={`/${siteSlug}/ai-frontiers/`}
              aria-current={isPathActive(pathname, `/${siteSlug}/ai-frontiers/`, "prefix") ? "page" : undefined}
            >
              AI Frontiers
            </a>
            <a
              href={`/${siteSlug}/privacy-security/`}
              aria-current={isPathActive(pathname, `/${siteSlug}/privacy-security/`, "prefix") ? "page" : undefined}
            >
              Privacy & Security
            </a>
            <a
              href={`/${siteSlug}/about/`}
              aria-current={isPathActive(pathname, `/${siteSlug}/about/`, "prefix") ? "page" : undefined}
            >
              About
            </a>
            <a
              href={`/${siteSlug}/contact/`}
              aria-current={isPathActive(pathname, `/${siteSlug}/contact/`, "prefix") ? "page" : undefined}
            >
              Contact
            </a>
          </nav>
        </div>
      </header>
    ) : null}

    <main class="main-content">
    <!-- Ezoic Sidebar Ad -->
    <div class="ad-slot ezoic-ad ezoic-ad-2" data-ezoic-ad-unit-id="sidebar-ad">
      <!-- Sidebar advertisement will be loaded here -->
    </div>

      <slot />
    </main>

    {!siteSlug ? (
      
    <!-- Ezoic Footer Ad -->
    <div class="ad-slot ezoic-ad ezoic-ad-4" data-ezoic-ad-unit-id="footer-ad">
      <!-- Footer advertisement will be loaded here -->
    </div>
<footer class="root-discovery-footer" aria-label="XML sitemaps and robots">
        <p>
          <a href={sitemapIndexHref}>Sitemap index (XML)</a>
          <span aria-hidden="true"> 路 </span>
          <a href={sitemapUrlsetHref}>Full URL list (XML)</a>
          <span aria-hidden="true"> 路 </span>
          <a href={htmlSitemapHref}>HTML site map</a>
          <span aria-hidden="true"> 路 </span>
          <a href={robotsTxtHref}>robots.txt</a>
        </p>
      </footer>
    ) : null}

    {/* Site Footer */}
    {siteSlug && siteName ? (
      <footer class="site-footer">
        <div class="footer-inner">
          <div class="footer-top">
            <div class="footer-brand">
              <strong>{siteName}</strong>
              {siteDescription ? <p class="footer-desc">{siteDescription}</p> : null}
            </div>
            <div class="footer-links">
              <a href="/">wordok.top</a>
              {allSites.map((s) => (
                <a href={`/${s.slug}/`}>{CHANNEL_LABELS[s.slug] ?? s.config.name}</a>
              ))}
              <a href={`/${siteSlug}/posts/`}>{postsNavLabel(siteSlug)}</a>
              <a href={`/${siteSlug}/ai-frontiers/`}>AI Frontiers</a>
              <a href={`/${siteSlug}/privacy-security/`}>Privacy & Security</a>
              <a href={`/${siteSlug}/about/`}>About</a>
              <a href={`/${siteSlug}/contact/`}>Contact</a>
              <a href={`/${siteSlug}/privacy/`}>Privacy</a>
              <a href={`/${siteSlug}/terms/`}>Terms</a>
              {hasAffiliates ? (
                <a href={`/${siteSlug}/disclosure/`}>Disclosure</a>
              ) : null}
              <a href="/sitemap/">Site Map</a>
              <a href={`/${siteSlug}/rss.xml`}>RSS</a>
              <a href={`/${siteSlug}/sitemap.xml`}>Sitemap</a>
            </div>
          </div>
          {/* 鍏ㄩ閬撳叧閿叆鍙ｏ細澧炲己浠庝换鎰忛〉闈㈠埌鍚勭珯棣栭〉/鍒楄〃/鏍忕洰鐨勭埇鍙栬矾寰?*/}
          <nav class="footer-channel-hubs" aria-label="All wordok.top channels">
            <p class="footer-hub-title">Explore all channels</p>
            <div class="footer-hub-row">
              {allSites.map((s) => (
                <span class="footer-hub-group">
                  <a href={`/${s.slug}/`}>{CHANNEL_LABELS[s.slug] ?? s.config.name}</a>
                  <span class="footer-hub-sep"> 路 </span>
                  <a href={`/${s.slug}/posts/`}>{postsHubLabel(s.slug)}</a>
                  <span class="footer-hub-sep"> 路 </span>
                  <a href={`/${s.slug}/ai-frontiers/`}>AI Frontiers</a>
                  <span class="footer-hub-sep"> 路 </span>
                  <a href={`/${s.slug}/privacy-security/`}>Privacy</a>
                </span>
              ))}
            </div>
          </nav>
          <p class="footer-copy">&copy; {currentYear} {siteName}. All rights reserved.</p>
        </div>
      </footer>
    ) : null}

    {/* Pagefind：延后到首次交互或浏览器空闲时再加载，减轻首屏 */}
    <script is:inline>
      (function() {
        var started = false;
        function loadPagefind() {
          if (started) return;
          started = true;
          var el = document.getElementById('search');
          if (!el) return;
          var link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = '/pagefind/pagefind-ui.css';
          document.head.appendChild(link);
          var script = document.createElement('script');
          script.src = '/pagefind/pagefind-ui.js';
          script.onload = function() {
            new PagefindUI({
              element: '#search',
              showSubResults: false,
              showImages: false,
              resetStyles: false
            });
          };
          script.onerror = function() {};
          document.head.appendChild(script);
        }
        document.addEventListener('pointerdown', loadPagefind, { capture: true, passive: true, once: true });
        document.addEventListener('keydown', loadPagefind, { capture: true, once: true });
        if (window.requestIdleCallback) {
          requestIdleCallback(loadPagefind, { timeout: 3500 });
        } else {
          setTimeout(loadPagefind, 2000);
        }
      })();
    </script>

    {/* Web Vitals 鐩戞帶 */}
    <script is:inline>
      (function() {
        function sendMetric(name, value, id) {
          if (typeof gtag === 'function') {
            gtag('event', name, {
              event_category: 'Web Vitals',
              value: Math.round(name === 'CLS' ? value * 1000 : value),
              event_label: id,
              non_interaction: true
            });
          }
          if (location.hostname === 'localhost' || location.hostname === '127.0.0.1') {
            console.log('[Web Vitals]', name + ':', value.toFixed(2));
          }
        }
        try {
          new PerformanceObserver(function(list) {
            var entries = list.getEntries();
            var last = entries[entries.length - 1];
            if (last) sendMetric('LCP', last.startTime, 'v1');
          }).observe({ type: 'largest-contentful-paint', buffered: true });

          var inpValue = 0;
          new PerformanceObserver(function(list) {
            list.getEntries().forEach(function(entry) {
              if (entry.duration > inpValue) inpValue = entry.duration;
            });
            sendMetric('INP', inpValue, 'v1');
          }).observe({ type: 'event', buffered: true, durationThreshold: 40 });

          var clsValue = 0;
          new PerformanceObserver(function(list) {
            list.getEntries().forEach(function(entry) {
              if (!entry.hadRecentInput) clsValue += entry.value;
            });
            sendMetric('CLS', clsValue, 'v1');
          }).observe({ type: 'layout-shift', buffered: true });

          new PerformanceObserver(function(list) {
            list.getEntries().forEach(function(entry) {
              if (entry.name === 'first-contentful-paint') {
                sendMetric('FCP', entry.startTime, 'v1');
              }
            });
          }).observe({ type: 'paint', buffered: true });

          if (performance.getEntriesByType) {
            var nav = performance.getEntriesByType('navigation')[0];
            if (nav) sendMetric('TTFB', nav.responseStart, 'v1');
          }
        } catch(e) {}
      })();
    </script>

    {/* Cookie banner removed - static site, no login required */}
  </body>
</html>

