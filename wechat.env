# 发布配置 - 安全第一，先发布到草稿箱
WECHAT_PUBLISH_TO_DRAFT=true
WECHAT_ARTICLE_COUNT=3
WECHAT_MIN_WORD_COUNT=1000

# 内容质量配置 - 高标准
WECHAT_REQUIRE_CITATIONS=true
WECHAT_INCLUDE_MEDIA=true
WECHAT_AUTO_TAGS=true

# 排版配置 - 确保合理排版
WECHAT_FORMAT_TITLE_MAX=30
WECHAT_FORMAT_SUMMARY_MAX=150
WECHAT_FORMAT_REQUIRE_SECTIONS=热点概述,技术分析,行业影响,未来展望,引用来源

# 执行时间配置
