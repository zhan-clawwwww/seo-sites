# SEO Daily Content Task Environment Variables
# Copy this file to .env and fill in your API keys

# ==================== Search APIs ====================

# Tavily Search API (Fallback 1)
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# NewsAPI (Fallback 2) 
# Get your API key from: https://newsapi.org/
NEWSAPI_API_KEY=your_newsapi_key_here

# ==================== Content Generation ====================

# OpenRouter API for AI content generation
OPENROUTER_API_KEY=your_openrouter_api_key_here

# DeepSeek API (alternative)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==================== Logging ====================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log file directory
LOG_DIR=./logs

# ==================== Search Configuration ====================

# Maximum search attempts per query
MAX_SEARCH_ATTEMPTS=3

# Search timeout in milliseconds
SEARCH_TIMEOUT_MS=15000

# Minimum results required before falling back
MIN_RESULTS_REQUIRED=3

# ==================== Content Quality ====================

# Minimum word count per article
MIN_WORD_COUNT=4000

# Maximum word count per article  
MAX_WORD_COUNT=5000

# Topic duplication check days
TOPIC_DUPLICATION_DAYS=3

# ==================== Fallback Topics ====================

# Enable fallback topic library
ENABLE_FALLBACK_TOPICS=true

# Fallback topic quality level: low, medium, high
FALLBACK_TOPIC_QUALITY=medium

# ==================== Git Configuration ====================

# Auto-push enabled
AUTO_PUSH_ENABLED=true

# Git commit message prefix
GIT_COMMIT_PREFIX="feat: auto-generate"

# ==================== Browser Automation ====================

# Enable browser automation fallback
ENABLE_BROWSER_AUTOMATION=true

# Browser timeout in seconds
BROWSER_TIMEOUT_SECONDS=30

# ==================== Notification ====================

# Enable summary before push
SHOW_SUMMARY_BEFORE_PUSH=true

# Notification channel (feishu, telegram, etc.)
NOTIFICATION_CHANNEL=feishu